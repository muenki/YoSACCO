<%- include('../partials/head', { title: 'Reports', activePage: 'admin-reports', group }) %>

<style>
@media print {
  .sidebar, .topbar, .no-print, .page-footer { display:none!important; }
  .main { margin-left:0!important; }
  .card { box-shadow:none!important; border:1px solid #ccc!important; }
  .page-content { padding:0!important; }
  .print-header { display:block!important; }
  body { font-size:12px; }
}
.print-header { display:none; text-align:center; margin-bottom:20px; }
</style>

<!-- Print Header (only shows when printing) -->
<div class="print-header">
  <h2 style="font-size:20px;"><%= group.name %></h2>
  <p><strong><%= period.charAt(0).toUpperCase()+period.slice(1) %> Report</strong> — 
  <%= start.toLocaleDateString('en-UG',{year:'numeric',month:'long',day:'numeric'}) %> to 
  <%= end.toLocaleDateString('en-UG',{year:'numeric',month:'long',day:'numeric'}) %></p>
  <p style="font-size:11px;color:#666;">Generated: <%= new Date().toLocaleString() %></p>
  <hr>
</div>

<!-- Period Selector -->
<div class="card mb-6 no-print">
  <div class="card-body">
    <form method="GET" action="/admin/reports" id="reportForm" style="display:flex;gap:12px;align-items:flex-end;flex-wrap:wrap;">
      <input type="hidden" name="tab" id="activeTab" value="<%= tab %>">
      <div class="form-group" style="margin:0;min-width:140px;">
        <label class="form-label">Period</label>
        <select name="period" class="form-control" onchange="this.form.submit()">
          <option value="monthly"   <%= period==='monthly'   ?'selected':'' %>>Monthly</option>
          <option value="quarterly" <%= period==='quarterly' ?'selected':'' %>>Quarterly</option>
          <option value="annual"    <%= period==='annual'    ?'selected':'' %>>Annual</option>
        </select>
      </div>
      <div class="form-group" style="margin:0;min-width:100px;">
        <label class="form-label">Year</label>
        <select name="year" class="form-control" onchange="this.form.submit()">
          <% years.forEach(y => { %><option value="<%= y %>" <%= y===year?'selected':'' %>><%= y %></option><% }) %>
        </select>
      </div>
      <% if (period==='quarterly') { %>
      <div class="form-group" style="margin:0;min-width:100px;">
        <label class="form-label">Quarter</label>
        <select name="quarter" class="form-control" onchange="this.form.submit()">
          <% quarters.forEach(q => { %><option value="<%= q %>" <%= q===quarter?'selected':'' %>>Q<%= q %></option><% }) %>
        </select>
      </div>
      <% } %>
      <% if (period==='monthly') { %>
      <div class="form-group" style="margin:0;min-width:130px;">
        <label class="form-label">Month</label>
        <select name="month" class="form-control" onchange="this.form.submit()">
          <% months.forEach((m,i) => { %><option value="<%= i %>" <%= i===month?'selected':'' %>><%= m %></option><% }) %>
        </select>
      </div>
      <% } %>
      <div style="display:flex;gap:8px;">
        <button type="button" onclick="window.print()" class="btn btn-primary no-print">🖨 Print Report</button>
      </div>
    </form>
  </div>
</div>

<!-- Report Period Label -->
<div class="flex-between mb-4">
  <h2 style="font-size:18px;">
    <%= period==='annual'?'Annual':period==='quarterly'?'Q'+quarter:months[month] %> Report — <%= year %>
    <span class="text-muted text-sm" style="font-weight:400;"> (<%= start.toLocaleDateString() %> – <%= end.toLocaleDateString() %>)</span>
  </h2>
</div>

<!-- Summary Cards -->
<div class="stats-grid mb-6">
  <div class="stat-card"><div class="label">Period Savings</div><div class="value" style="font-size:18px;">UGX <%= totalPeriodSavings.toLocaleString() %></div></div>
  <div class="stat-card"><div class="label">Interest Income</div><div class="value" style="font-size:18px;">UGX <%= periodInterest.toLocaleString() %></div></div>
  <div class="stat-card"><div class="label">Expenditure</div><div class="value" style="font-size:18px;color:var(--danger);">UGX <%= totalExpend.toLocaleString() %></div></div>
  <div class="stat-card accent"><div class="label">Available Balance</div><div class="value" style="font-size:18px;">UGX <%= availableBalance.toLocaleString() %></div></div>
</div>

<!-- Tabs -->
<div class="tab-nav no-print">
  <% [['savings','💰 Savings'],['loans','📋 Loan Portfolio'],['interest','📊 Interest Distribution'],['expenditure','💸 Expenditure'],['projects','🏗️ Projects'],['summary','📄 Full Summary']].forEach(([t,label])=>{ %>
  <button class="tab-btn <%= tab===t?'active':'' %>" onclick="switchTab('<%= t %>')"><%= label %></button>
  <% }) %>
</div>

<!-- ══ SAVINGS TAB ══════════════════════════════════════════════ -->
<div class="tab-pane <%= tab==='savings'?'active':'' %>" id="tab-savings">
  <div class="flex-between mb-3">
    <h3>Member Savings — <%= period==='annual'?year:period==='quarterly'?'Q'+quarter+' '+year:months[month]+' '+year %></h3>
    <button onclick="window.print()" class="btn btn-sm btn-outline no-print">🖨 Print</button>
  </div>
  <div class="card p-0">
    <div class="table-wrap">
      <table>
        <thead><tr><th>#</th><th>Member</th><th>Member ID</th><th>Period Savings</th><th>Total Balance</th><th>Share Capital</th><th>Total Assets</th></tr></thead>
        <tbody>
          <% memberSavings.forEach((m,i) => { %>
          <tr>
            <td class="text-muted text-sm"><%= i+1 %></td>
            <td><div class="font-semibold text-sm"><%= m.name %></div></td>
            <td class="text-sm"><%= m.memberId||'—' %></td>
            <td class="font-semibold text-teal">UGX <%= m.periodSavings.toLocaleString() %></td>
            <td class="font-semibold">UGX <%= m.totalBalance.toLocaleString() %></td>
            <td>UGX <%= (m.shareCapitalPaid||0).toLocaleString() %></td>
            <td class="font-semibold">UGX <%= ((m.totalBalance||0)+(m.shareCapitalPaid||0)).toLocaleString() %></td>
          </tr>
          <% }) %>
          <tr style="background:var(--bg);font-weight:700;">
            <td colspan="3" style="text-align:right;padding:10px 16px;">TOTAL</td>
            <td style="padding:10px 16px;color:var(--teal);">UGX <%= totalPeriodSavings.toLocaleString() %></td>
            <td style="padding:10px 16px;">UGX <%= memberSavings.reduce((t,m)=>t+m.totalBalance,0).toLocaleString() %></td>
            <td style="padding:10px 16px;">UGX <%= memberSavings.reduce((t,m)=>t+(m.shareCapitalPaid||0),0).toLocaleString() %></td>
            <td style="padding:10px 16px;">UGX <%= memberSavings.reduce((t,m)=>t+m.totalBalance+(m.shareCapitalPaid||0),0).toLocaleString() %></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- ══ LOANS TAB ════════════════════════════════════════════════ -->
<div class="tab-pane <%= tab==='loans'?'active':'' %>" id="tab-loans">
  <div class="flex-between mb-3">
    <h3>Loan Portfolio Report</h3>
    <button onclick="window.print()" class="btn btn-sm btn-outline no-print">🖨 Print</button>
  </div>
  <div class="stats-grid mb-4">
    <div class="stat-card"><div class="label">Active Loans</div><div class="value"><%= activeLoans.length %></div></div>
    <div class="stat-card"><div class="label">Outstanding</div><div class="value" style="font-size:16px;">UGX <%= activeLoans.reduce((t,l)=>t+(l.totalRepayable-l.amountRepaid),0).toLocaleString() %></div></div>
    <div class="stat-card"><div class="label">Repaid (Period)</div><div class="value" style="font-size:16px;">UGX <%= totalRepaid.toLocaleString() %></div></div>
    <div class="stat-card"><div class="label">Applied (Period)</div><div class="value"><%= loansInPeriod.length %></div></div>
  </div>
  <div class="card p-0">
    <div class="table-wrap">
      <table>
        <thead><tr><th>Member</th><th>Type</th><th>Amount</th><th>Total Repayable</th><th>Repaid</th><th>Outstanding</th><th>Status</th></tr></thead>
        <tbody>
          <% activeLoans.forEach(l => { %>
          <tr>
            <td><div class="font-semibold text-sm"><%= l.member?.name||'—' %></div><div class="text-xs text-muted"><%= l.member?.memberId %></div></td>
            <td><span class="badge badge-info" style="font-size:10px;"><%= l.loanType==='new_loan'?'New':l.loanType==='top_up'?'Top-Up':'Emergency' %></span></td>
            <td class="text-sm">UGX <%= l.amount.toLocaleString() %></td>
            <td class="text-sm">UGX <%= l.totalRepayable.toLocaleString() %></td>
            <td class="text-sm text-success">UGX <%= l.amountRepaid.toLocaleString() %></td>
            <td class="text-sm font-semibold text-danger">UGX <%= (l.totalRepayable-l.amountRepaid).toLocaleString() %></td>
            <td><span class="badge badge-info" style="font-size:10px;">Active</span></td>
          </tr>
          <% }) %>
          <tr style="background:var(--bg);font-weight:700;">
            <td colspan="4" style="text-align:right;padding:10px 16px;">TOTALS</td>
            <td style="padding:10px 16px;color:var(--success);">UGX <%= activeLoans.reduce((t,l)=>t+l.amountRepaid,0).toLocaleString() %></td>
            <td style="padding:10px 16px;color:var(--danger);">UGX <%= activeLoans.reduce((t,l)=>t+(l.totalRepayable-l.amountRepaid),0).toLocaleString() %></td>
            <td></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- ══ INTEREST DISTRIBUTION TAB ════════════════════════════════ -->
<div class="tab-pane <%= tab==='interest'?'active':'' %>" id="tab-interest">
  <div class="flex-between mb-3">
    <h3>Interest Distribution</h3>
    <button onclick="window.print()" class="btn btn-sm btn-outline no-print">🖨 Print</button>
  </div>
  <div class="alert alert-info mb-4">
    <strong>Distribution Method:</strong>
    <%= method==='share_capital_only'?'Share Capital Only':method==='savings_only'?'Savings Balance Only':'Share Capital + Savings Balance' %> ·
    <strong>Total Interest Pool:</strong> UGX <%= totalInterestPool.toLocaleString() %>
  </div>
  <div class="card p-0">
    <div class="table-wrap">
      <table>
        <thead><tr><th>Member</th><th>Share Capital</th><th>Savings Balance</th><th>Weight</th><th>% Share</th><th>Interest Due</th></tr></thead>
        <tbody>
          <% interestDistribution.forEach(m => { %>
          <tr>
            <td><div class="font-semibold text-sm"><%= m.name %></div><div class="text-xs text-muted"><%= m.memberId %></div></td>
            <td class="text-sm">UGX <%= (m.shareCapitalPaid||0).toLocaleString() %></td>
            <td class="text-sm">UGX <%= (memberSavings.find(ms=>ms.id===m.id)?.totalBalance||0).toLocaleString() %></td>
            <td class="text-sm">UGX <%= (m.weight||0).toLocaleString() %></td>
            <td class="text-sm"><%= totalInterestPool>0?((m.weight/interestDistribution.reduce((t,x)=>t+x.weight,0))*100).toFixed(1):'0' %>%</td>
            <td class="font-semibold text-teal">UGX <%= m.interestShare.toLocaleString() %></td>
          </tr>
          <% }) %>
          <tr style="background:var(--bg);font-weight:700;">
            <td colspan="5" style="text-align:right;padding:10px 16px;">TOTAL DISTRIBUTED</td>
            <td style="padding:10px 16px;color:var(--teal);">UGX <%= interestDistribution.reduce((t,m)=>t+m.interestShare,0).toLocaleString() %></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- ══ EXPENDITURE TAB ══════════════════════════════════════════ -->
<div class="tab-pane <%= tab==='expenditure'?'active':'' %>" id="tab-expenditure">
  <div class="flex-between mb-3">
    <h3>Expenditure Ledger</h3>
    <button onclick="window.print()" class="btn btn-sm btn-outline no-print">🖨 Print Ledger</button>
  </div>
  <div class="card p-0">
    <div class="table-wrap">
      <table>
        <thead><tr><th>Date</th><th>Category</th><th>Description</th><th>Amount (UGX)</th></tr></thead>
        <tbody>
          <% expenditures.forEach(e => { %>
          <tr>
            <td class="text-sm text-muted"><%= new Date(e.date).toLocaleDateString('en-UG',{year:'numeric',month:'short',day:'numeric'}) %></td>
            <td><span class="badge badge-gray text-xs"><%= e.category %></span></td>
            <td class="text-sm"><%= e.description||'—' %></td>
            <td class="font-semibold text-danger">UGX <%= e.amount.toLocaleString() %></td>
          </tr>
          <% }) %>
          <% if (!expenditures.length) { %><tr><td colspan="4" style="text-align:center;padding:20px;color:var(--text-muted);">No expenditures in this period.</td></tr><% } %>
          <tr style="background:var(--bg);font-weight:700;">
            <td colspan="3" style="text-align:right;padding:10px 16px;">TOTAL EXPENDITURE</td>
            <td style="padding:10px 16px;color:var(--danger);">UGX <%= totalExpend.toLocaleString() %></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- ══ PROJECTS TAB ══════════════════════════════════════════════ -->
<div class="tab-pane <%= tab==='projects'?'active':'' %>" id="tab-projects">
  <div class="flex-between mb-3">
    <h3>Projects & Contributions</h3>
    <button onclick="window.print()" class="btn btn-sm btn-outline no-print">🖨 Print</button>
  </div>
  <div class="card p-0">
    <div class="table-wrap">
      <table>
        <thead><tr><th>Project</th><th>Type</th><th>Target</th><th>Raised</th><th>Progress</th><th>Status</th></tr></thead>
        <tbody>
          <% projects.forEach(p => { const pct = p.targetAmount>0?Math.round(p.raisedAmount/p.targetAmount*100):0; %>
          <tr>
            <td><div class="font-semibold text-sm"><%= p.name %></div><% if(p.returnRate>0){ %><div class="text-xs text-muted"><%= p.returnRate %>% annual return</div><% } %></td>
            <td><span class="badge badge-gray text-xs"><%= p.type.replace('_',' ') %></span></td>
            <td class="text-sm">UGX <%= p.targetAmount.toLocaleString() %></td>
            <td class="text-sm font-semibold">UGX <%= p.raisedAmount.toLocaleString() %></td>
            <td style="min-width:100px;"><div class="progress" style="height:6px;"><div class="progress-bar" style="width:<%= pct %>%"></div></div><div class="text-xs text-muted mt-1"><%= pct %>%</div></td>
            <td><span class="badge badge-<%= p.status==='active'?'success':'warning' %>"><%= p.status %></span></td>
          </tr>
          <% }) %>
          <% if (!projects.length) { %><tr><td colspan="6" style="text-align:center;padding:20px;color:var(--text-muted);">No projects yet.</td></tr><% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- ══ FULL SUMMARY TAB ══════════════════════════════════════════ -->
<div class="tab-pane <%= tab==='summary'?'active':'' %>" id="tab-summary">
  <div class="flex-between mb-3">
    <h3>Full Summary Report — <%= period==='annual'?year:period==='quarterly'?'Q'+quarter+' '+year:months[month]+' '+year %></h3>
    <button onclick="window.print()" class="btn btn-primary no-print">🖨 Print Full Report</button>
  </div>

  <div class="card mb-4">
    <div class="card-header"><h3>📊 Income Summary</h3></div>
    <div class="card-body">
      <div class="info-list">
        <div class="info-item"><span class="info-key">Member Savings (Period)</span><span class="info-val text-success">+ UGX <%= totalPeriodSavings.toLocaleString() %></span></div>
        <div class="info-item"><span class="info-key">Interest Income (Period)</span><span class="info-val text-success">+ UGX <%= periodInterest.toLocaleString() %></span></div>
        <div class="info-item"><span class="info-key">Project Contributions</span><span class="info-val text-success">+ UGX <%= totalProjectContribs.toLocaleString() %></span></div>
        <div class="info-item" style="font-weight:700;"><span class="info-key">TOTAL INCOME</span><span class="info-val text-teal">UGX <%= (totalPeriodSavings+periodInterest+totalProjectContribs).toLocaleString() %></span></div>
      </div>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-header"><h3>💸 Expenditure Summary</h3></div>
    <div class="card-body">
      <div class="info-list">
        <% const catTotals = {}; expenditures.forEach(e=>{catTotals[e.category]=(catTotals[e.category]||0)+e.amount;}); %>
        <% Object.entries(catTotals).forEach(([cat,amt])=>{ %>
        <div class="info-item"><span class="info-key"><%= cat %></span><span class="info-val text-danger">- UGX <%= amt.toLocaleString() %></span></div>
        <% }) %>
        <div class="info-item" style="font-weight:700;"><span class="info-key">TOTAL EXPENDITURE</span><span class="info-val text-danger">UGX <%= totalExpend.toLocaleString() %></span></div>
      </div>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-header"><h3>📋 Loan Portfolio Summary</h3></div>
    <div class="card-body">
      <div class="info-list">
        <div class="info-item"><span class="info-key">Active Loans</span><span class="info-val"><%= activeLoans.length %> loans</span></div>
        <div class="info-item"><span class="info-key">Total Outstanding</span><span class="info-val text-danger">UGX <%= loanPortfolio.toLocaleString() %></span></div>
        <div class="info-item"><span class="info-key">Total Repaid (Period)</span><span class="info-val text-success">UGX <%= totalRepaid.toLocaleString() %></span></div>
        <div class="info-item"><span class="info-key">Lifetime Interest Income</span><span class="info-val text-teal">UGX <%= interestIncome.toLocaleString() %></span></div>
      </div>
    </div>
  </div>

  <div class="card" style="border:2px solid var(--teal);">
    <div class="card-header" style="background:var(--navy);color:#fff;border-radius:12px 12px 0 0;"><h3 style="color:#fff;">💰 Available Balance</h3></div>
    <div class="card-body">
      <div class="info-list">
        <div class="info-item"><span class="info-key">Total Savings Collected (All Time)</span><span class="info-val">UGX <%= totalSavingsEver.toLocaleString() %></span></div>
        <div class="info-item"><span class="info-key">Total Expenditure (All Time)</span><span class="info-val text-danger">- UGX <%= totalExpendsEver.toLocaleString() %></span></div>
        <div class="info-item"><span class="info-key">Loan Portfolio Outstanding</span><span class="info-val text-danger">- UGX <%= loanPortfolio.toLocaleString() %></span></div>
        <div class="info-item" style="font-size:18px;font-weight:700;border-top:2px solid var(--teal);margin-top:8px;padding-top:12px;">
          <span class="info-key">AVAILABLE BALANCE</span>
          <span class="info-val" style="color:var(--teal);font-size:22px;">UGX <%= availableBalance.toLocaleString() %></span>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
function switchTab(t) {
  document.querySelectorAll('.tab-pane').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('tab-'+t).classList.add('active');
  document.querySelectorAll('.tab-btn').forEach(b=>{ if(b.textContent.includes(t)||b.getAttribute('onclick').includes("'"+t+"'")) b.classList.add('active'); });
  document.getElementById('activeTab').value=t;
}
// Activate correct tab btn on load
document.querySelectorAll('.tab-btn').forEach(b => {
  if (b.getAttribute('onclick') && b.getAttribute('onclick').includes("'<%= tab %>'")) b.classList.add('active');
});
</script>
<%- include('../partials/foot') %>
