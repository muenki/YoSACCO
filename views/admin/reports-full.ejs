<%- include('../partials/head', { title: 'Reports', activePage: 'admin-reports', group }) %>

<style>
/* Single tab print — visibility trick */
body.printing-tab .sidebar,
body.printing-tab .topbar,
body.printing-tab .page-footer,
body.printing-tab .no-print,
body.printing-tab .tab-nav,
body.printing-tab .form-group { display:none!important; }
body.printing-tab .main { margin-left:0!important; }
body.printing-tab .page-content { padding:8px!important; }

@media print {
  body.printing-tab .sidebar,
  body.printing-tab .topbar,
  body.printing-tab .page-footer,
  body.printing-tab .no-print,
  body.printing-tab .tab-nav { display:none!important; }
  body.printing-tab .main { margin-left:0!important; }

  /* Hide ALL tab panes */
  body.printing-tab .tab-pane { display:none!important; }
  /* Show ONLY the selected tab */
  body.printing-tab .tab-pane.printing { display:block!important; }

  /* Print All mode — show everything */
  body.printing-all .sidebar,
  body.printing-all .topbar,
  body.printing-all .page-footer,
  body.printing-all .no-print,
  body.printing-all .tab-nav { display:none!important; }
  body.printing-all .main { margin-left:0!important; }
  body.printing-all .tab-pane { display:block!important; }
  body.printing-all .print-header { display:block!important; }

  .card { box-shadow:none!important; border:1px solid #ccc!important; break-inside:avoid; }
  table { font-size:11px; }
  .print-header { display:block!important; }
}
.print-header { display:none; }
</style>

<!-- Universal Print Header -->
<div class="print-header" style="text-align:center;margin-bottom:24px;padding-bottom:16px;border-bottom:2px solid #ccc;">
  <% if(group.logo){ %><img src="<%= group.logo %>" style="height:60px;margin-bottom:8px;"><br><% } %>
  <h2 style="font-size:20px;margin:0;"><%= group.name %></h2>
  <p style="font-size:14px;margin:4px 0;"><strong><%= period==='annual'?'Annual':period==='quarterly'?'Q'+quarter+' Quarterly':'Monthly' %> Report — <%= period==='annual'?year:period==='quarterly'?'Q'+quarter+' '+year:months[month]+' '+year %></strong></p>
  <p style="font-size:12px;color:#666;">Period: <%= start.toLocaleDateString('en-UG',{year:'numeric',month:'long',day:'numeric'}) %> to <%= end.toLocaleDateString('en-UG',{year:'numeric',month:'long',day:'numeric'}) %></p>
  <p style="font-size:11px;color:#888;">Generated: <%= new Date().toLocaleString() %></p>
</div>

<!-- Period Selector -->
<form method="GET" action="/admin/reports" id="reportForm" class="no-print">
  <div class="card mb-4">
    <div class="card-body" style="display:flex;gap:12px;align-items:flex-end;flex-wrap:wrap;">
      <input type="hidden" name="tab" id="activeTab" value="<%= tab %>">
      <div class="form-group" style="margin:0;min-width:140px;">
        <label class="form-label">Period</label>
        <select name="period" class="form-control" onchange="this.form.submit()">
          <option value="monthly"   <%= period==='monthly'  ?'selected':'' %>>Monthly</option>
          <option value="quarterly" <%= period==='quarterly'?'selected':'' %>>Quarterly</option>
          <option value="annual"    <%= period==='annual'   ?'selected':'' %>>Annual</option>
        </select>
      </div>
      <div class="form-group" style="margin:0;min-width:100px;">
        <label class="form-label">Year</label>
        <select name="year" class="form-control" onchange="this.form.submit()">
          <% years.forEach(function(y){ %><option value="<%= y %>" <%= y===year?'selected':'' %>><%= y %></option><% }); %>
        </select>
      </div>
      <% if(period==='quarterly'){ %>
      <div class="form-group" style="margin:0;min-width:100px;">
        <label class="form-label">Quarter</label>
        <select name="quarter" class="form-control" onchange="this.form.submit()">
          <% [1,2,3,4].forEach(function(q){ %><option value="<%= q %>" <%= q===quarter?'selected':'' %>>Q<%= q %></option><% }); %>
        </select>
      </div>
      <% } %>
      <% if(period==='monthly'){ %>
      <div class="form-group" style="margin:0;min-width:130px;">
        <label class="form-label">Month</label>
        <select name="month" class="form-control" onchange="this.form.submit()">
          <% months.forEach(function(m,i){ %><option value="<%= i %>" <%= i===month?'selected':'' %>><%= m %></option><% }); %>
        </select>
      </div>
      <% } %>
      <button type="button" onclick="printAll()" class="btn btn-primary">🖨 Print All Reports</button>
    </div>
  </div>
</form>

<!-- Period Label -->
<div class="flex-between mb-4 no-print">
  <h2 style="font-size:18px;">
    <%= period==='annual'?year+' Annual':period==='quarterly'?'Q'+quarter+' '+year:months[month]+' '+year %> Report
    <span class="text-muted text-sm" style="font-weight:400;"> — <%= start.toLocaleDateString() %> to <%= end.toLocaleDateString() %></span>
  </h2>
</div>

<!-- Summary Stats -->
<div class="stats-grid mb-4">
  <div class="stat-card"><div class="label">Period Savings</div><div class="value" style="font-size:18px;">UGX <%= totalPeriodSavings.toLocaleString() %></div></div>
  <div class="stat-card"><div class="label">Interest Income</div><div class="value" style="font-size:18px;">UGX <%= periodInterest.toLocaleString() %></div></div>
  <div class="stat-card"><div class="label">Expenditure</div><div class="value" style="font-size:18px;color:var(--danger);">UGX <%= totalExpend.toLocaleString() %></div></div>
  <div class="stat-card accent"><div class="label">Available Balance</div><div class="value" style="font-size:18px;">UGX <%= availableBalance.toLocaleString() %></div></div>
</div>

<!-- Tabs -->
<div class="tab-nav no-print">
  <% var tabs = [['savings','💰 Savings'],['loans','📋 Loans'],['interest','📊 Distribution'],['expenditure','💸 Expenditure'],['projects','🏗️ Projects'],['project_collections','📦 Collections'],['assets','🏛️ Assets'],['summary','📄 Summary']]; %>
  <% tabs.forEach(function(t){ %>
  <button class="tab-btn <%= tab===t[0]?'active':'' %>" onclick="switchTab('<%= t[0] %>')"><%= t[1] %></button>
  <% }); %>
</div>

<!-- ══ SAVINGS ══════════════════════════════════════════════════ -->
<div class="tab-pane <%= tab==='savings'?'active':'' %>" id="tab-savings">
  <div class="flex-between mb-3">
    <h3>Savings Report — <%= period==='annual'?year:period==='quarterly'?'Q'+quarter+' '+year:months[month]+' '+year %></h3>
    <button onclick="printTab('savings')" class="btn btn-sm btn-outline no-print">🖨 Print</button>
  </div>
  <div class="card p-0">
    <div class="table-wrap">
      <table>
        <thead><tr><th>#</th><th>Member</th><th>ID</th><th>Period Savings</th><th>Total Balance</th><th>Share Capital</th><th>Total Member Assets</th></tr></thead>
        <tbody>
          <% memberSavings.forEach(function(m, i){ %>
          <tr>
            <td class="text-muted text-sm"><%= i+1 %></td>
            <td class="font-semibold text-sm"><%= m.name %></td>
            <td class="text-sm"><%= m.memberId||'—' %></td>
            <td class="font-semibold text-teal">UGX <%= m.periodSavings.toLocaleString() %></td>
            <td class="font-semibold">UGX <%= m.totalBalance.toLocaleString() %></td>
            <td>UGX <%= (m.shareCapitalPaid||0).toLocaleString() %></td>
            <td class="font-semibold">UGX <%= ((m.totalBalance||0)+(m.shareCapitalPaid||0)).toLocaleString() %></td>
          </tr>
          <% }); %>
          <tr style="background:var(--bg);font-weight:700;">
            <td colspan="3" style="text-align:right;padding:10px 16px;">TOTAL</td>
            <td style="padding:10px 16px;color:var(--teal);">UGX <%= totalPeriodSavings.toLocaleString() %></td>
            <td style="padding:10px 16px;">UGX <%= memberSavings.reduce(function(t,m){return t+m.totalBalance;},0).toLocaleString() %></td>
            <td style="padding:10px 16px;">UGX <%= memberSavings.reduce(function(t,m){return t+(m.shareCapitalPaid||0);},0).toLocaleString() %></td>
            <td style="padding:10px 16px;">UGX <%= memberSavings.reduce(function(t,m){return t+m.totalBalance+(m.shareCapitalPaid||0);},0).toLocaleString() %></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- ══ LOANS ════════════════════════════════════════════════════ -->
<div class="tab-pane <%= tab==='loans'?'active':'' %>" id="tab-loans">
  <div class="flex-between mb-3">
    <h3>Loan Portfolio Report</h3>
    <button onclick="printTab('loans')" class="btn btn-sm btn-outline no-print">🖨 Print</button>
  </div>
  <div class="stats-grid mb-4" style="grid-template-columns:repeat(4,1fr);">
    <div class="stat-card"><div class="label">Active Loans</div><div class="value"><%= activeLoans.length %></div></div>
    <div class="stat-card"><div class="label">Outstanding</div><div class="value" style="font-size:16px;">UGX <%= activeLoans.reduce(function(t,l){return t+(l.totalRepayable-l.amountRepaid);},0).toLocaleString() %></div></div>
    <div class="stat-card"><div class="label">Repaid (Period)</div><div class="value" style="font-size:16px;">UGX <%= totalRepaid.toLocaleString() %></div></div>
    <div class="stat-card"><div class="label">New Applications</div><div class="value"><%= loansInPeriod.length %></div></div>
  </div>
  <div class="card p-0">
    <div class="table-wrap">
      <table>
        <thead><tr><th>Member</th><th>Type</th><th>Loan Amount</th><th>Total Repayable</th><th>Repaid</th><th>Outstanding</th><th>Monthly</th><th>Status</th></tr></thead>
        <tbody>
          <% activeLoans.forEach(function(l){ %>
          <tr>
            <td><div class="font-semibold text-sm"><%= l.member?l.member.name:'—' %></div><div class="text-xs text-muted"><%= l.member?l.member.memberId:'' %></div></td>
            <td><span class="badge badge-info" style="font-size:10px;"><%= l.loanType==='new_loan'?'New':l.loanType==='top_up'?'Top-Up':'Emergency' %></span></td>
            <td class="text-sm">UGX <%= l.amount.toLocaleString() %></td>
            <td class="text-sm">UGX <%= l.totalRepayable.toLocaleString() %></td>
            <td class="text-sm text-success">UGX <%= l.amountRepaid.toLocaleString() %></td>
            <td class="text-sm font-semibold text-danger">UGX <%= (l.totalRepayable-l.amountRepaid).toLocaleString() %></td>
            <td class="text-sm">UGX <%= l.monthlyInstallment.toLocaleString() %></td>
            <td><span class="badge badge-info" style="font-size:10px;">Active</span></td>
          </tr>
          <% }); %>
          <% if(!activeLoans.length){ %><tr><td colspan="8" style="text-align:center;padding:20px;color:var(--text-muted);">No active loans.</td></tr><% } %>
          <tr style="background:var(--bg);font-weight:700;">
            <td colspan="4" style="text-align:right;padding:10px 16px;">TOTALS</td>
            <td style="padding:10px 16px;color:var(--success);">UGX <%= activeLoans.reduce(function(t,l){return t+l.amountRepaid;},0).toLocaleString() %></td>
            <td style="padding:10px 16px;color:var(--danger);">UGX <%= activeLoans.reduce(function(t,l){return t+(l.totalRepayable-l.amountRepaid);},0).toLocaleString() %></td>
            <td colspan="2"></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- ══ INTEREST ══════════════════════════════════════════════════ -->
<div class="tab-pane <%= tab==='interest'?'active':'' %>" id="tab-interest">
  <div class="flex-between mb-3">
    <h3>Income Distribution (Interest + Other Income)</h3>
    <button onclick="printTab('interest')" class="btn btn-sm btn-outline no-print">🖨 Print</button>
  </div>

  <% if (locals.query && locals.query.prompt_distribute) { %>
<div class="alert" style="background:#fff8e1;border:2px solid #FFC000;border-radius:8px;padding:14px 18px;margin-bottom:16px;">
  <strong>💰 Other Income Recorded: UGX <%= parseInt(locals.query.income_amount||0).toLocaleString() %> from <%= locals.query.income_source||'' %></strong><br>
  <span style="font-size:13px;">This income should be distributed to members now. Review the distribution below and click <strong>Post Distribution</strong>.</span>
</div>
<% } %>
<% if (locals.query && locals.query.success === 'distributed') { %>
  <div class="alert alert-success no-print">
    ✅ Distribution posted successfully! Each member's savings balance has been credited with their share.
  </div>
  <% } %>
  <% if (locals.query && locals.query.error === 'nothing_to_distribute') { %>
  <div class="alert alert-warning no-print">No income to distribute in this period.</div>
  <% } %>

  <div class="alert alert-info mb-3">
    <strong>Distribution Method:</strong>
    <%= method==='share_capital_only'?'Share Capital Only':method==='savings_only'?'Savings Only':'Share Capital + Savings' %>
    <br>
    <span style="font-size:13px;">
      <strong>Loan Interest:</strong> UGX <%= periodInterest.toLocaleString() %>
      &nbsp;+&nbsp;
      <strong>Other Income:</strong> UGX <%= (locals.totalOtherIncomePeriod||0).toLocaleString() %>
      &nbsp;−&nbsp;
      <strong>Period Expenditure:</strong> UGX <%= totalExpend.toLocaleString() %>
      &nbsp;=&nbsp;
      <strong style="color:var(--teal);">Net Distributable Pool: UGX <%= (locals.totalDistributionPool||totalInterestPool).toLocaleString() %></strong>
    </span>
  </div>

  <!-- Distribute Button -->
  <%
    var _interestAmt  = locals.periodInterestDisplay || 0;
    var _otherAmt     = locals.totalOtherIncomePeriod || 0;
    var _periodLabel  = period==='annual'?year:period==='quarterly'?'Q'+quarter+' '+year:months[month]+' '+year;
  %>

  <!-- INTEREST INCOME DISTRIBUTION -->
  <% if (_interestAmt > 0) { %>
  <div class="card mb-4 no-print" style="border-left:4px solid #0D7377;background:#f0f9f9;">
    <div class="card-body">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
        <div>
          <div class="font-semibold" style="font-size:15px;">📈 Loan Interest Income</div>
          <div class="text-sm text-muted">Accrued loan interest for <%= _periodLabel %></div>
        </div>
        <div style="font-size:22px;font-weight:800;color:#0D7377;">UGX <%= _interestAmt.toLocaleString() %></div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <form method="POST" action="/admin/reports/distribute" style="display:flex;gap:6px;flex-direction:column;">
          <input type="hidden" name="period"          value="<%= period %>">
          <input type="hidden" name="year"            value="<%= year %>">
          <input type="hidden" name="quarter"         value="<%= quarter %>">
          <input type="hidden" name="month"           value="<%= month %>">
          <input type="hidden" name="distribute_type" value="savings">
          <input type="hidden" name="income_type"     value="interest">
          <input type="text"   name="description"     class="form-control" value="Loan interest distribution — <%= _periodLabel %>">
          <button type="submit" class="btn btn-success"
            onclick="return confirm('Add UGX <%= _interestAmt.toLocaleString() %> loan interest to member savings?\n\nSavings balances will increase. Available balance stays the same.')">
            💰 Add to Member Savings
          </button>
        </form>
        <form method="POST" action="/admin/reports/distribute" style="display:flex;gap:6px;flex-direction:column;">
          <input type="hidden" name="period"          value="<%= period %>">
          <input type="hidden" name="year"            value="<%= year %>">
          <input type="hidden" name="quarter"         value="<%= quarter %>">
          <input type="hidden" name="month"           value="<%= month %>">
          <input type="hidden" name="distribute_type" value="payout">
          <input type="hidden" name="income_type"     value="interest">
          <input type="text"   name="description"     class="form-control" value="Loan interest payout — <%= _periodLabel %>">
          <button type="submit" class="btn btn-primary"
            onclick="return confirm('Pay out UGX <%= _interestAmt.toLocaleString() %> loan interest in cash?\n\nEach member will receive an email with their payout amount.\nMember savings will NOT change. Available balance will drop.')">
            💸 Cash Payout (+ Email Members)
          </button>
        </form>
      </div>
    </div>
  </div>
  <% } %>

  <!-- OTHER INCOME DISTRIBUTION -->
  <% if (_otherAmt > 0) { %>
  <div class="card mb-4 no-print" style="border-left:4px solid #FFC000;background:#fffbeb;">
    <div class="card-body">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
        <div>
          <div class="font-semibold" style="font-size:15px;">💵 Other Income</div>
          <div class="text-sm text-muted">Grants, donations, fines, and other income for <%= _periodLabel %></div>
        </div>
        <div style="font-size:22px;font-weight:800;color:#b7791f;">UGX <%= _otherAmt.toLocaleString() %></div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <form method="POST" action="/admin/reports/distribute" style="display:flex;gap:6px;flex-direction:column;">
          <input type="hidden" name="period"          value="<%= period %>">
          <input type="hidden" name="year"            value="<%= year %>">
          <input type="hidden" name="quarter"         value="<%= quarter %>">
          <input type="hidden" name="month"           value="<%= month %>">
          <input type="hidden" name="distribute_type" value="savings">
          <input type="hidden" name="income_type"     value="other_income">
          <input type="text"   name="description"     class="form-control" value="Other income distribution — <%= _periodLabel %>">
          <button type="submit" class="btn btn-success"
            onclick="return confirm('Add UGX <%= _otherAmt.toLocaleString() %> other income to member savings?\n\nSavings balances will increase proportionally.')">
            💰 Add to Member Savings
          </button>
        </form>
        <form method="POST" action="/admin/reports/distribute" style="display:flex;gap:6px;flex-direction:column;">
          <input type="hidden" name="period"          value="<%= period %>">
          <input type="hidden" name="year"            value="<%= year %>">
          <input type="hidden" name="quarter"         value="<%= quarter %>">
          <input type="hidden" name="month"           value="<%= month %>">
          <input type="hidden" name="distribute_type" value="payout">
          <input type="hidden" name="income_type"     value="other_income">
          <input type="text"   name="description"     class="form-control" value="Other income payout — <%= _periodLabel %>">
          <button type="submit" class="btn btn-primary"
            onclick="return confirm('Pay out UGX <%= _otherAmt.toLocaleString() %> other income in cash?\n\nEach member will receive an email with their payout amount.\nMember savings will NOT change.')">
            💸 Cash Payout (+ Email Members)
          </button>
        </form>
      </div>
    </div>
  </div>
  <% } %>

  <% if (_interestAmt <= 0 && _otherAmt <= 0) { %>
  <div class="card mb-4" style="border-left:4px solid #ccc;background:#f9f9f9;">
    <div class="card-body text-sm text-muted">No distributable income for this period.</div>
  </div>
  <% } %>
  <div class="card p-0">
    <div class="table-wrap">
      <table>
        <thead><tr><th>Member</th><th>Share Capital</th><th>Savings Balance</th><th>Weight</th><th>Share %</th><th>Distribution Due (UGX)</th></tr></thead>
        <tbody>
          <%
            var totalWeight = interestDistribution.reduce(function(t,m){return t+m.weight;},0);
          %>
          <% interestDistribution.forEach(function(m){ %>
          <tr>
            <td><div class="font-semibold text-sm"><%= m.name %></div><div class="text-xs text-muted"><%= m.memberId %></div></td>
            <td class="text-sm">UGX <%= (m.shareCapitalPaid||0).toLocaleString() %></td>
            <td class="text-sm">UGX <%= (m.totalBalance||0).toLocaleString() %></td>
            <td class="text-sm">UGX <%= (m.weight||0).toLocaleString() %></td>
            <td class="text-sm"><%= totalWeight>0?((m.weight/totalWeight)*100).toFixed(1):'0' %>%</td>
            <td class="font-semibold text-teal">UGX <%= m.interestShare.toLocaleString() %></td>
          </tr>
          <% }); %>
          <tr style="background:var(--bg);font-weight:700;">
            <td colspan="5" style="text-align:right;padding:10px 16px;">TOTAL DISTRIBUTED</td>
            <td style="padding:10px 16px;color:var(--teal);">UGX <%= interestDistribution.reduce(function(t,m){return t+m.interestShare;},0).toLocaleString() %></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- ══ EXPENDITURE ═══════════════════════════════════════════════ -->
<div class="tab-pane <%= tab==='expenditure'?'active':'' %>" id="tab-expenditure">
  <div class="flex-between mb-3">
    <h3>Expenditure Ledger</h3>
    <button onclick="printTab('expenditure')" class="btn btn-sm btn-outline no-print">🖨 Print Ledger</button>
  </div>
  <div class="card p-0">
    <div class="table-wrap">
      <table>
        <thead><tr><th>#</th><th>Date</th><th>Category</th><th>Description</th><th>Amount (UGX)</th></tr></thead>
        <tbody>
          <% expenditures.forEach(function(e, i){ %>
          <tr>
            <td class="text-muted text-sm"><%= i+1 %></td>
            <td class="text-sm text-muted"><%= new Date(e.date).toLocaleDateString('en-UG',{year:'numeric',month:'short',day:'numeric'}) %></td>
            <td><span class="badge badge-gray text-xs"><%= e.category %></span></td>
            <td class="text-sm"><%= e.description||'—' %></td>
            <td class="font-semibold text-danger">UGX <%= e.amount.toLocaleString() %></td>
          </tr>
          <% }); %>
          <% if(!expenditures.length){ %><tr><td colspan="5" style="text-align:center;padding:20px;color:var(--text-muted);">No expenditures in this period.</td></tr><% } %>
          <tr style="background:var(--bg);font-weight:700;">
            <td colspan="4" style="text-align:right;padding:10px 16px;">TOTAL EXPENDITURE</td>
            <td style="padding:10px 16px;color:var(--danger);">UGX <%= totalExpend.toLocaleString() %></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- ══ PROJECTS ══════════════════════════════════════════════════ -->
<div class="tab-pane <%= tab==='projects'?'active':'' %>" id="tab-projects">
  <div class="flex-between mb-3">
    <h3>Projects Report</h3>
    <button onclick="printTab('projects')" class="btn btn-sm btn-outline no-print">🖨 Print</button>
  </div>
  <div class="card p-0">
    <div class="table-wrap">
      <table>
        <thead><tr><th>Project</th><th>Type</th><th>Target</th><th>Raised</th><th>Progress</th><th>Return Rate</th><th>Status</th></tr></thead>
        <tbody>
          <% projects.forEach(function(p){ var pct=p.targetAmount>0?Math.round(p.raisedAmount/p.targetAmount*100):0; %>
          <tr>
            <td><div class="font-semibold text-sm"><%= p.name %></div><% if(p.description){ %><div class="text-xs text-muted"><%= p.description.slice(0,60) %></div><% } %></td>
            <td><span class="badge badge-gray text-xs" style="text-transform:capitalize;"><%= p.type.replace(/_/g,' ') %></span></td>
            <td class="text-sm">UGX <%= p.targetAmount.toLocaleString() %></td>
            <td class="text-sm font-semibold text-teal">UGX <%= p.raisedAmount.toLocaleString() %></td>
            <td style="min-width:90px;"><div class="progress" style="height:5px;"><div class="progress-bar" style="width:<%= pct %>%"></div></div><div class="text-xs text-muted mt-1"><%= pct %>%</div></td>
            <td class="text-sm"><%= p.returnRate>0?p.returnRate+'% p.a.':'—' %></td>
            <td><span class="badge badge-<%= p.status==='active'?'success':'warning' %>" style="font-size:10px;"><%= p.status %></span></td>
          </tr>
          <% }); %>
          <% if(!projects.length){ %><tr><td colspan="7" style="text-align:center;padding:20px;color:var(--text-muted);">No projects.</td></tr><% } %>
          <tr style="background:var(--bg);font-weight:700;">
            <td colspan="3" style="text-align:right;padding:10px 16px;">TOTAL RAISED</td>
            <td style="padding:10px 16px;color:var(--teal);">UGX <%= projects.reduce(function(t,p){return t+p.raisedAmount;},0).toLocaleString() %></td>
            <td colspan="3"></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- ══ ASSETS ════════════════════════════════════════════════════ -->
<div class="tab-pane <%= tab==='project_collections'?'active':'' %>" id="tab-project_collections">
  <div class="flex-between mb-3">
    <h3>Project Collections Summary</h3>
    <button onclick="printTab('project_collections')" class="btn btn-sm btn-outline no-print">Print</button>
  </div>
  <% (locals.projectCollections||[]).forEach(function(proj){ %>
  <div class="card mb-4">
    <div class="card-body">
      <div class="flex-between mb-2">
        <div>
          <div class="font-semibold" style="font-size:16px;"><%= proj.name %></div>
          <div class="text-sm text-muted"><%= proj.type.replace(/_/g,' ') %> · <%= proj.status %></div>
        </div>
        <div class="text-sm" style="text-align:right;">
          Target: <strong>UGX <%= proj.targetAmount.toLocaleString() %></strong><br>
          Collected: <strong class="text-teal">UGX <%= proj.totalContrib.toLocaleString() %></strong><br>
          Progress: <strong><%= proj.targetAmount>0?((proj.totalContrib/proj.targetAmount)*100).toFixed(1):0 %>%</strong>
        </div>
      </div>
      <div class="progress mb-3"><div class="progress-bar" style="width:<%= proj.targetAmount>0?Math.min(100,(proj.totalContrib/proj.targetAmount)*100):0 %>%"></div></div>
      <table>
        <thead><tr><th>#</th><th>Member</th><th>Member ID</th><th>Amount</th><th>% of Target</th><th>% of Raised</th></tr></thead>
        <tbody>
          <% proj.memberContribs.sort(function(a,b){return b.amount-a.amount;}).forEach(function(mc,i){ %>
          <tr>
            <td class="text-sm text-muted"><%= i+1 %></td>
            <td class="font-semibold text-sm"><%= mc.member?mc.member.name:'Unknown' %></td>
            <td class="text-sm"><%= mc.member?mc.member.memberId:'—' %></td>
            <td class="font-semibold text-teal">UGX <%= mc.amount.toLocaleString() %></td>
            <td class="text-sm"><%= proj.targetAmount>0?((mc.amount/proj.targetAmount)*100).toFixed(1):0 %>%</td>
            <td class="text-sm"><%= proj.totalContrib>0?((mc.amount/proj.totalContrib)*100).toFixed(1):0 %>%</td>
          </tr>
          <% }); %>
          <tr style="background:var(--bg);font-weight:700;">
            <td colspan="3" style="text-align:right;padding:10px;">TOTAL</td>
            <td style="padding:10px;color:var(--teal);">UGX <%= proj.totalContrib.toLocaleString() %></td>
            <td><%= proj.targetAmount>0?((proj.totalContrib/proj.targetAmount)*100).toFixed(1):0 %>%</td>
            <td></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
  <% }); %>
  <% if(!(locals.projectCollections||[]).length){ %><div class="card"><div class="card-body text-muted text-sm">No projects found.</div></div><% } %>
</div>

<div class="tab-pane <%= tab==='assets'?'active':'' %>" id="tab-assets">
  <div class="flex-between mb-3">
    <h3>Asset Register</h3>
    <button onclick="printTab('assets')" class="btn btn-sm btn-outline no-print">🖨 Print</button>
  </div>
  <div class="card p-0">
    <div class="table-wrap">
      <table>
        <thead><tr><th>#</th><th>Asset</th><th>Category</th><th>Purchase Value</th><th>Current Value</th><th>Date</th><th>Condition</th><th>Status</th></tr></thead>
        <tbody>
          <% (locals.allAssets||[]).forEach(function(a, i){ %>
          <tr>
            <td class="text-sm text-muted"><%= i+1 %></td>
            <td><div class="font-semibold text-sm"><%= a.name %></div><% if(a.location){ %><div class="text-xs text-muted"><%= a.location %></div><% } %></td>
            <td><span class="badge badge-gray text-xs" style="text-transform:capitalize;"><%= a.category.replace(/_/g,' ') %></span></td>
            <td class="text-sm">UGX <%= a.purchaseValue.toLocaleString() %></td>
            <td class="text-sm font-semibold">UGX <%= a.currentValue.toLocaleString() %></td>
            <td class="text-sm text-muted"><%= a.purchaseDate?new Date(a.purchaseDate).toLocaleDateString():'—' %></td>
            <td><span class="badge text-xs badge-<%= a.condition==='excellent'||a.condition==='good'?'success':'warning' %>"><%= a.condition %></span></td>
            <td><span class="badge text-xs badge-<%= a.status==='active'?'success':'warning' %>"><%= a.status.replace(/_/g,' ') %></span></td>
          </tr>
          <% }); %>
          <% if(!(locals.allAssets||[]).length){ %><tr><td colspan="8" style="text-align:center;padding:20px;color:var(--text-muted);">No assets recorded.</td></tr><% } %>
          <tr style="background:var(--bg);font-weight:700;">
            <td colspan="3" style="text-align:right;padding:10px 16px;">TOTALS</td>
            <td style="padding:10px 16px;">UGX <%= (locals.allAssets||[]).reduce(function(t,a){return t+a.purchaseValue;},0).toLocaleString() %></td>
            <td style="padding:10px 16px;">UGX <%= (locals.allAssets||[]).reduce(function(t,a){return t+a.currentValue;},0).toLocaleString() %></td>
            <td colspan="3"></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- ══ SUMMARY ═══════════════════════════════════════════════════ -->
<div class="tab-pane <%= tab==='summary'?'active':'' %>" id="tab-summary">
  <div class="flex-between mb-3">
    <h3>General Summary Report — <%= period==='annual'?year:period==='quarterly'?'Q'+quarter+' '+year:months[month]+' '+year %></h3>
    <button onclick="printTab('summary')" class="btn btn-primary no-print">🖨 Print Summary</button>
  </div>

  <div class="grid-2 gap-4 mb-4">
    <div class="card">
      <div class="card-header" style="background:var(--navy);border-radius:12px 12px 0 0;"><h3 style="color:#fff;">💰 Savings & Capital</h3></div>
      <div class="card-body">
        <div class="info-list">
          <div class="info-item"><span class="info-key">Period Savings</span><span class="info-val text-success">UGX <%= totalPeriodSavings.toLocaleString() %></span></div>
          <div class="info-item"><span class="info-key">Total Savings (All Time)</span><span class="info-val">UGX <%= totalSavingsEver.toLocaleString() %></span></div>
          <div class="info-item"><span class="info-key">Total Share Capital</span><span class="info-val">UGX <%= memberSavings.reduce(function(t,m){return t+(m.shareCapitalPaid||0);},0).toLocaleString() %></span></div>
          <div class="info-item"><span class="info-key">Members</span><span class="info-val"><%= memberSavings.length %></span></div>
        </div>
      </div>
    </div>
    <div class="card">
      <div class="card-header" style="background:var(--teal);border-radius:12px 12px 0 0;"><h3 style="color:#fff;">📋 Loan Portfolio</h3></div>
      <div class="card-body">
        <div class="info-list">
          <div class="info-item"><span class="info-key">Active Loans</span><span class="info-val"><%= activeLoans.length %></span></div>
          <div class="info-item"><span class="info-key">Outstanding Balance</span><span class="info-val text-danger">UGX <%= loanPortfolio.toLocaleString() %></span></div>
          <div class="info-item"><span class="info-key">Repaid (Period)</span><span class="info-val text-success">UGX <%= totalRepaid.toLocaleString() %></span></div>
          <div class="info-item"><span class="info-key">Interest Accrued (Period)</span><span class="info-val text-teal">UGX <%= periodInterest.toLocaleString() %></span></div>
        </div>
      </div>
    </div>
    <div class="card">
      <div class="card-header" style="background:#7B2D8B;border-radius:12px 12px 0 0;"><h3 style="color:#fff;">🏗️ Projects & Assets</h3></div>
      <div class="card-body">
        <div class="info-list">
          <div class="info-item"><span class="info-key">Active Projects</span><span class="info-val"><%= projects.filter(function(p){return p.status==='active';}).length %></span></div>
          <div class="info-item"><span class="info-key">Total Raised (Projects)</span><span class="info-val">UGX <%= projects.reduce(function(t,p){return t+p.raisedAmount;},0).toLocaleString() %></span></div>
          <div class="info-item"><span class="info-key">Assets (Current Value)</span><span class="info-val">UGX <%= (locals.allAssets||[]).filter(function(a){return a.status==='active';}).reduce(function(t,a){return t+a.currentValue;},0).toLocaleString() %></span></div>
          <div class="info-item"><span class="info-key">Number of Assets</span><span class="info-val"><%= (locals.allAssets||[]).filter(function(a){return a.status==='active';}).length %></span></div>
        </div>
      </div>
    </div>
    <div class="card">
      <div class="card-header" style="background:var(--danger);border-radius:12px 12px 0 0;"><h3 style="color:#fff;">💸 Expenditure</h3></div>
      <div class="card-body">
        <div class="info-list">
          <div class="info-item"><span class="info-key">Period Expenditure</span><span class="info-val text-danger">UGX <%= totalExpend.toLocaleString() %></span></div>
          <div class="info-item"><span class="info-key">Total Expenditure (All Time)</span><span class="info-val text-danger">UGX <%= totalExpendsEver.toLocaleString() %></span></div>
          <div class="info-item"><span class="info-key">Transactions</span><span class="info-val"><%= expenditures.length %></span></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Available Balance Box -->
  <div class="card" style="border:3px solid var(--teal);">
    <div class="card-header" style="background:linear-gradient(135deg,var(--navy),#1a3a5c);border-radius:10px 10px 0 0;">
      <h3 style="color:#fff;font-size:18px;">📊 <%= group.name %> — Financial Position Summary</h3>
    </div>
    <div class="card-body">
      <div class="grid-2 gap-4">
        <div>
          <p class="text-sm font-semibold mb-3" style="color:var(--success);">INCOME / ASSETS</p>
          <div class="info-list">
            <div class="info-item"><span class="info-key">Total Savings (All Time)</span><span class="info-val text-success">+ UGX <%= totalSavingsEver.toLocaleString() %></span></div>
            <div class="info-item"><span class="info-key">Total Share Capital</span><span class="info-val text-success">+ UGX <%= (locals.totalShareCapital||0).toLocaleString() %></span></div>
            <div class="info-item"><span class="info-key">Other Income (All Time)</span><span class="info-val text-success">+ UGX <%= (locals.totalOtherIncomeEver||0).toLocaleString() %></span></div>
            <div class="info-item"><span class="info-key">Interest Income (Period)</span><span class="info-val text-success">+ UGX <%= periodInterest.toLocaleString() %></span></div>
            <div class="info-item"><span class="info-key">Project Contributions</span><span class="info-val text-success">+ UGX <%= totalProjectContribs.toLocaleString() %></span></div>
            <div class="info-item"><span class="info-key">Asset Value</span><span class="info-val text-success">+ UGX <%= (locals.allAssets||[]).filter(function(a){return a.status==='active';}).reduce(function(t,a){return t+a.currentValue;},0).toLocaleString() %></span></div>
          </div>
        </div>
        <div>
          <p class="text-sm font-semibold mb-3" style="color:var(--danger);">LIABILITIES / OUTFLOWS</p>
          <div class="info-list">
            <div class="info-item"><span class="info-key">Total Expenditure</span><span class="info-val text-danger">- UGX <%= totalExpendsEver.toLocaleString() %></span></div>
            <div class="info-item"><span class="info-key">Loan Portfolio (Outstanding)</span><span class="info-val text-danger">- UGX <%= loanPortfolio.toLocaleString() %></span></div>
          </div>
        </div>
      </div>
      <hr style="border:none;border-top:2px solid var(--teal);margin:20px 0;">
      <div style="background:var(--bg);border-radius:8px;padding:14px 16px;margin-bottom:16px;font-size:13px;color:var(--text-muted);">
        <strong style="color:var(--navy);">Balance Formula:</strong>
        UGX <%= totalSavingsEver.toLocaleString() %> (savings) + UGX <%= (locals.totalShareCapital||0).toLocaleString() %> (share capital)
        + UGX <%= (locals.totalOtherIncomeEver||0).toLocaleString() %> (other income)
        − UGX <%= totalExpendsEver.toLocaleString() %> (expenditure)
        − UGX <%= loanPortfolio.toLocaleString() %> (loans outstanding)
        = <strong style="color:<%= availableBalance >= 0 ? 'var(--success)' : 'var(--danger)' %>">UGX <%= availableBalance.toLocaleString() %></strong>
      </div>
      <div class="flex-between">
        <div style="font-size:18px;font-weight:700;">NET AVAILABLE BALANCE</div>
        <div style="font-size:28px;font-weight:800;color:<%= availableBalance >= 0 ? 'var(--teal)' : 'var(--danger)' %>;">UGX <%= availableBalance.toLocaleString() %></div>
      </div>
    </div>
  </div>
</div>

<script>
function switchTab(t) {
  document.querySelectorAll('.tab-pane').forEach(function(p){p.classList.remove('active');});
  document.querySelectorAll('.tab-btn').forEach(function(b){b.classList.remove('active');});
  var el = document.getElementById('tab-'+t);
  if(el) el.classList.add('active');
  document.querySelectorAll('.tab-btn').forEach(function(b){
    if(b.getAttribute('onclick') && b.getAttribute('onclick').indexOf("'"+t+"'")>-1) b.classList.add('active');
  });
  document.getElementById('activeTab').value = t;
}

function printTab(t) {
  // Switch to the tab first
  switchTab(t);

  // Mark the target tab for print-only visibility
  document.querySelectorAll('.tab-pane').forEach(function(p){ p.classList.remove('printing'); });
  var target = document.getElementById('tab-' + t);
  if (!target) return;
  target.classList.add('printing');

  // Apply printing class to body
  document.body.classList.add('printing-tab');
  window.print();

  // Cleanup after print dialog closes
  setTimeout(function() {
    document.body.classList.remove('printing-tab');
    target.classList.remove('printing');
  }, 2000);
}

function printAll() {
  document.body.classList.add('printing-all');
  window.print();
  setTimeout(function() {
    document.body.classList.remove('printing-all');
  }, 2000);
}
</script>
