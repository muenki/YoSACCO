<%- include('../partials/head', { title: 'My Invoices', activePage: 'admin-invoices', group }) %>

<style>
/* Always hide templates on screen */
.inv-template { display: none !important; }

/* When printing — hide EVERYTHING except the selected template */
@media print {
  * { visibility: hidden; }
  .inv-template.selected,
  .inv-template.selected * { visibility: visible; }
  .inv-template.selected {
    display: block !important;
    position: fixed;
    top: 0; left: 0;
    width: 100%;
  }
}
</style>

<!-- One hidden printable block per invoice -->
<% invoices.forEach(function(inv, idx){ %>
<div class="inv-template" id="invt-<%= idx %>">
  <div style="max-width:660px;margin:40px auto;font-family:Arial,sans-serif;padding:36px;border:1px solid #ddd;border-radius:8px;">
    <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:28px;">
      <div>
        <img src="/assets/logo.png" style="height:48px;margin-bottom:8px;display:block;" onerror="this.style.display='none'">
        <div style="font-size:13px;color:#666;"><%= group.name %></div>
        <div style="font-size:12px;color:#999;margin-top:2px;"><%= group.adminEmail %></div>
      </div>
      <div style="text-align:right;">
        <div style="font-size:28px;font-weight:800;color:#0D7377;letter-spacing:-1px;">INVOICE</div>
        <div style="font-size:15px;font-weight:700;color:#0A2342;margin-top:2px;"><%= inv.invoiceNumber %></div>
        <div style="font-size:12px;color:#666;margin-top:6px;">Issued: <%= new Date(inv.createdAt).toLocaleDateString('en-UG',{day:'numeric',month:'long',year:'numeric'}) %></div>
        <div style="font-size:12px;color:#666;">Due: <%= new Date(inv.dueDate).toLocaleDateString('en-UG',{day:'numeric',month:'long',year:'numeric'}) %></div>
      </div>
    </div>

    <div style="display:flex;gap:32px;background:#f6f8fa;padding:16px 20px;border-radius:8px;margin-bottom:24px;">
      <div>
        <div style="font-size:10px;font-weight:700;color:#999;text-transform:uppercase;letter-spacing:.06em;margin-bottom:5px;">From</div>
        <div style="font-weight:700;color:#0A2342;">YoSACCO Platform</div>
        <div style="font-size:13px;color:#555;">info@yosacco.coop</div>
        <div style="font-size:13px;color:#555;">+256 756 683 141</div>
        <div style="font-size:13px;color:#555;">Kampala, Uganda</div>
      </div>
      <div>
        <div style="font-size:10px;font-weight:700;color:#999;text-transform:uppercase;letter-spacing:.06em;margin-bottom:5px;">To</div>
        <div style="font-weight:700;color:#0A2342;"><%= group.name %></div>
        <div style="font-size:13px;color:#555;"><%= group.adminEmail %></div>
      </div>
    </div>

    <table style="width:100%;border-collapse:collapse;margin-bottom:24px;">
      <thead>
        <tr style="background:#0A2342;color:#fff;">
          <th style="padding:11px 14px;text-align:left;font-size:13px;">Description</th>
          <th style="padding:11px 14px;text-align:center;font-size:13px;">Period</th>
          <th style="padding:11px 14px;text-align:right;font-size:13px;">Amount (UGX)</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td style="padding:13px 14px;font-size:13px;border-bottom:1px solid #eee;">
            YoSACCO <%= inv.type==='annual'?'Annual':'Monthly' %> Subscription
          </td>
          <td style="padding:13px 14px;text-align:center;font-size:12px;color:#666;border-bottom:1px solid #eee;">
            <% if(inv.periodStart && inv.periodEnd){ %><%= new Date(inv.periodStart).toLocaleDateString() %> – <%= new Date(inv.periodEnd).toLocaleDateString() %><% } else { %>—<% } %>
          </td>
          <td style="padding:13px 14px;text-align:right;font-weight:700;font-size:14px;border-bottom:1px solid #eee;">
            UGX <%= inv.amount.toLocaleString() %>
          </td>
        </tr>
      </tbody>
    </table>

    <div style="display:flex;justify-content:flex-end;margin-bottom:24px;">
      <div style="border:2px solid #0D7377;border-radius:10px;padding:16px 28px;text-align:right;min-width:200px;">
        <div style="font-size:11px;color:#888;text-transform:uppercase;letter-spacing:.06em;">Total Due</div>
        <div style="font-size:26px;font-weight:800;color:#0D7377;margin:4px 0;">UGX <%= inv.amount.toLocaleString() %></div>
        <span style="display:inline-block;padding:4px 14px;border-radius:20px;font-size:12px;font-weight:700;background:<%= inv.status==='paid'?'#d6f0e4':inv.status==='overdue'?'#fed7d7':'#fefcbf' %>;color:<%= inv.status==='paid'?'#1a7f4b':inv.status==='overdue'?'#c53030':'#b7791f' %>;">
          <%= inv.status.toUpperCase() %>
        </span>
      </div>
    </div>

    <div style="border-top:1px solid #eee;padding-top:14px;font-size:12px;color:#888;line-height:1.7;">
      <strong style="color:#444;">Payment Instructions:</strong>
      Pay via MTN MoMo, Airtel Money or Bank Transfer to YoSACCO.
      Reference: <strong style="color:#0A2342;"><%= inv.invoiceNumber %></strong> ·
      +256 756 683 141 · info@yosacco.coop
    </div>

    <% if(inv.status==='paid'){ %>
    <div style="margin-top:14px;padding:10px 16px;background:#d6f0e4;border-radius:8px;font-size:13px;color:#1a7f4b;font-weight:700;">
      ✓ PAYMENT RECEIVED — UGX <%= inv.paidAmount.toLocaleString() %> on
      <%= new Date(inv.paidAt).toLocaleDateString('en-UG',{day:'numeric',month:'long',year:'numeric'}) %>
    </div>
    <% } %>

    <div style="text-align:center;margin-top:24px;font-size:11px;color:#bbb;border-top:1px solid #eee;padding-top:12px;">
      Powered by YoSACCO · www.yosacco.coop · +256 756 683 141
    </div>
  </div>
</div>
<% }); %>

<!-- ── Normal screen content ──────────────────────────────────── -->
<div class="stats-grid mb-6">
  <div class="stat-card"><div class="label">Total Invoices</div><div class="value"><%= invoices.length %></div></div>
  <div class="stat-card"><div class="label">Paid</div><div class="value text-success"><%= invoices.filter(function(i){return i.status==='paid';}).length %></div></div>
  <div class="stat-card"><div class="label">Pending</div><div class="value" style="color:var(--warning);"><%= invoices.filter(function(i){return i.status==='pending';}).length %></div></div>
  <div class="stat-card"><div class="label">Total Paid</div><div class="value" style="font-size:18px;">UGX <%= invoices.filter(function(i){return i.status==='paid';}).reduce(function(s,i){return s+i.paidAmount;},0).toLocaleString() %></div></div>
</div>

<% if(invoices.filter(function(i){return i.status==='pending';}).length > 0){ %>
<div class="alert alert-warning mb-4">
  <strong><%= invoices.filter(function(i){return i.status==='pending';}).length %> pending invoice(s).</strong>
  Contact YoSACCO: <strong>+256 756 683 141</strong>
</div>
<% } %>

<div class="section-head"><h2>Invoice History</h2></div>

<% if(!invoices.length){ %>
<div class="card"><div class="card-body text-muted text-sm">No invoices yet.</div></div>
<% } %>

<% invoices.forEach(function(inv, idx){ %>
<div class="invoice-card <%= inv.status %>" style="margin-bottom:14px;">
  <div class="flex-between mb-2">
    <div>
      <div class="font-semibold"><%= inv.invoiceNumber %></div>
      <div class="text-xs text-muted">
        <%= inv.type==='annual'?'Annual':'Monthly' %> Subscription
        <% if(inv.periodStart){ %> · <%= new Date(inv.periodStart).toLocaleDateString() %> – <%= new Date(inv.periodEnd).toLocaleDateString() %><% } %>
      </div>
    </div>
    <div class="flex gap-2" style="align-items:center;">
      <span class="badge badge-<%= inv.status==='paid'?'success':inv.status==='overdue'?'danger':'warning' %>">
        <%= inv.status.charAt(0).toUpperCase()+inv.status.slice(1) %>
      </span>
      <button onclick="printInvoice(<%= idx %>)" class="btn btn-sm btn-outline">🖨 Print</button>
    </div>
  </div>
  <div class="flex gap-3 text-sm">
    <span class="font-semibold">UGX <%= inv.amount.toLocaleString() %></span>
    <span class="text-muted">·</span>
    <span class="text-muted">Due: <%= new Date(inv.dueDate).toLocaleDateString() %></span>
    <% if(inv.status==='paid' && inv.paidAt){ %>
      <span class="text-muted">·</span>
      <span class="text-success">Paid <%= new Date(inv.paidAt).toLocaleDateString() %></span>
    <% } %>
  </div>
  <% if(inv.status==='pending'){ %>
  <div class="mt-2 text-xs text-muted">Reference: <strong><%= inv.invoiceNumber %></strong> · +256 756 683 141</div>
  <% } %>
</div>
<% }); %>

<script>
function printInvoice(idx) {
  // Remove selected from any previous
  var prev = document.querySelector('.inv-template.selected');
  if (prev) prev.classList.remove('selected');

  // Mark the chosen one
  var target = document.getElementById('invt-' + idx);
  if (!target) return;
  target.classList.add('selected');

  // Print — CSS visibility trick ensures only selected shows
  window.print();

  // Clean up after dialog closes
  setTimeout(function() {
    target.classList.remove('selected');
  }, 2000);
}
</script>

<%- include('../partials/foot') %>
