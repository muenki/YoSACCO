<%- include('../partials/head', { title: 'Asset Management', activePage: 'admin-assets', group }) %>

<style>
@media print {
  .sidebar,.topbar,.no-print,.page-footer { display:none!important; }
  .main { margin-left:0!important; }
  .card { box-shadow:none!important; border:1px solid #ccc!important; }
  .print-header { display:block!important; }
}
.print-header { display:none; text-align:center; margin-bottom:20px; }
</style>

<div class="print-header">
  <% if(group.logo){ %><img src="<%= group.logo %>" style="height:60px;margin-bottom:8px;"><br><% } %>
  <h2><%= group.name %> — Asset Register</h2>
  <p>Printed: <%= new Date().toLocaleDateString('en-UG',{year:'numeric',month:'long',day:'numeric'}) %></p>
  <hr>
</div>

<% if (locals.query && locals.query.success === 'asset_added')   { %><div class="alert alert-success no-print">Asset added successfully.</div><% } %>
<% if (locals.query && locals.query.success === 'asset_updated') { %><div class="alert alert-success no-print">Asset updated successfully.</div><% } %>

<div class="stats-grid mb-6">
  <div class="stat-card accent"><div class="label">Total Assets</div><div class="value"><%= assets.filter(function(a){return a.status==='active';}).length %></div></div>
  <div class="stat-card"><div class="label">Purchase Value</div><div class="value" style="font-size:18px;">UGX <%= (totalPurchase/1000000).toFixed(2) %>M</div></div>
  <div class="stat-card"><div class="label">Current Value</div><div class="value" style="font-size:18px;">UGX <%= (totalCurrent/1000000).toFixed(2) %>M</div></div>
  <div class="stat-card"><div class="label">Depreciation</div><div class="value" style="font-size:18px;color:var(--danger);">UGX <%= (totalPurchase-totalCurrent).toLocaleString() %></div></div>
</div>

<div class="grid-2 gap-4 mb-6">
  <!-- Add Asset Form -->
  <div class="card no-print">
    <div class="card-header"><h3>Add New Asset</h3></div>
    <div class="card-body">
      <form method="POST" action="/admin/assets/add">
        <div class="form-group">
          <label class="form-label">Asset Name *</label>
          <input type="text" name="name" class="form-control" placeholder="e.g. Dell Laptop" required>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Category</label>
            <select name="category" class="form-control">
              <option value="property">Property / Land</option>
              <option value="vehicle">Vehicle</option>
              <option value="equipment">Equipment</option>
              <option value="furniture">Furniture</option>
              <option value="investment">Investment</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Condition</label>
            <select name="condition" class="form-control">
              <option value="excellent">Excellent</option>
              <option value="good" selected>Good</option>
              <option value="fair">Fair</option>
              <option value="poor">Poor</option>
            </select>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Purchase Value (UGX) *</label>
            <input type="number" name="purchaseValue" class="form-control" placeholder="e.g. 2500000" required>
          </div>
          <div class="form-group">
            <label class="form-label">Current Value (UGX)</label>
            <input type="number" name="currentValue" class="form-control" placeholder="Leave blank = purchase value">
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Purchase Date</label>
            <input type="date" name="purchaseDate" class="form-control">
          </div>
          <div class="form-group">
            <label class="form-label">Location</label>
            <input type="text" name="location" class="form-control" placeholder="e.g. SACCO Office">
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Description</label>
          <textarea name="description" class="form-control" rows="2" placeholder="Brief description..."></textarea>
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;">Add Asset</button>
      </form>
    </div>
  </div>

  <!-- Summary by Category -->
  <div class="card">
    <div class="card-header"><h3>By Category</h3></div>
    <div class="card-body">
      <%
        var catMap = {};
        assets.filter(function(a){ return a.status==='active'; }).forEach(function(a){
          catMap[a.category] = (catMap[a.category]||0) + a.currentValue;
        });
        var catEntries = Object.keys(catMap).sort(function(x,y){ return catMap[y]-catMap[x]; });
      %>
      <% if (catEntries.length === 0) { %>
        <p class="text-muted text-sm">No assets recorded yet.</p>
      <% } %>
      <% catEntries.forEach(function(cat) { %>
      <div class="flex-between mb-2">
        <span class="text-sm" style="text-transform:capitalize;"><%= cat.replace(/_/g,' ') %></span>
        <span class="text-sm font-semibold">UGX <%= catMap[cat].toLocaleString() %></span>
      </div>
      <div class="progress mb-3" style="height:4px;">
        <div class="progress-bar" style="width:<%= totalCurrent>0?Math.round(catMap[cat]/totalCurrent*100):0 %>%;"></div>
      </div>
      <% }); %>
    </div>
  </div>
</div>

<!-- Asset Register Table -->
<div class="flex-between mb-3 no-print">
  <h2>Asset Register (<%= assets.length %>)</h2>
  <button onclick="window.print()" class="btn btn-sm btn-outline">🖨 Print Register</button>
</div>

<div class="card p-0">
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Asset Name</th>
          <th>Category</th>
          <th>Purchase Value</th>
          <th>Current Value</th>
          <th>Purchase Date</th>
          <th>Condition</th>
          <th>Status</th>
          <th class="no-print">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (!assets.length) { %>
        <tr><td colspan="9" style="text-align:center;padding:24px;color:var(--text-muted);">No assets recorded yet.</td></tr>
        <% } %>
        <% assets.forEach(function(a, idx) { %>
        <tr>
          <td class="text-muted text-sm"><%= idx+1 %></td>
          <td>
            <div class="font-semibold text-sm"><%= a.name %></div>
            <% if(a.location){ %><div class="text-xs text-muted"><%= a.location %></div><% } %>
            <% if(a.description){ %><div class="text-xs text-muted"><%= a.description %></div><% } %>
          </td>
          <td><span class="badge badge-gray text-xs" style="text-transform:capitalize;"><%= a.category.replace(/_/g,' ') %></span></td>
          <td class="text-sm">UGX <%= a.purchaseValue.toLocaleString() %></td>
          <td class="text-sm font-semibold">UGX <%= a.currentValue.toLocaleString() %></td>
          <td class="text-sm text-muted"><%= a.purchaseDate ? new Date(a.purchaseDate).toLocaleDateString() : '—' %></td>
          <td>
            <span class="badge text-xs badge-<%= a.condition==='excellent'||a.condition==='good'?'success':a.condition==='fair'?'warning':'danger' %>">
              <%= a.condition %>
            </span>
          </td>
          <td>
            <span class="badge text-xs badge-<%= a.status==='active'?'success':'warning' %>">
              <%= a.status.replace(/_/g,' ') %>
            </span>
          </td>
          <td class="no-print">
            <button onclick="openEditAsset(this)" 
              data-id="<%= a.id %>"
              data-name="<%= a.name %>"
              data-category="<%= a.category %>"
              data-value="<%= a.currentValue %>"
              data-condition="<%= a.condition %>"
              data-status="<%= a.status %>"
              data-location="<%= a.location||'' %>"
              data-desc="<%= (a.description||'').replace(/\"/g, '&quot;') %>"
              class="btn btn-sm btn-outline">Edit</button>
          </td>
        </tr>
        <% }); %>
        <tr style="background:var(--bg);font-weight:700;">
          <td colspan="3" style="padding:10px 16px;text-align:right;">TOTALS</td>
          <td style="padding:10px 16px;">UGX <%= totalPurchase.toLocaleString() %></td>
          <td style="padding:10px 16px;">UGX <%= totalCurrent.toLocaleString() %></td>
          <td colspan="4"></td>
        </tr>
      </tbody>
    </table>
  </div>
</div>

<!-- Edit Modal -->
<div id="editModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.45);z-index:999;align-items:center;justify-content:center;">
  <div class="card" style="width:500px;max-height:92vh;overflow-y:auto;">
    <div class="card-header">
      <h3>Edit Asset</h3>
      <button onclick="document.getElementById('editModal').style.display='none'" style="background:none;border:none;cursor:pointer;font-size:20px;line-height:1;">✕</button>
    </div>
    <div class="card-body">
      <form id="editForm" method="POST">
        <div class="form-group">
          <label class="form-label">Asset Name</label>
          <input type="text" name="name" id="edit-name" class="form-control" required>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Category</label>
            <select name="category" id="edit-category" class="form-control">
              <option value="property">Property / Land</option>
              <option value="vehicle">Vehicle</option>
              <option value="equipment">Equipment</option>
              <option value="furniture">Furniture</option>
              <option value="investment">Investment</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Current Value (UGX)</label>
            <input type="number" name="currentValue" id="edit-value" class="form-control">
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Condition</label>
            <select name="condition" id="edit-condition" class="form-control">
              <option value="excellent">Excellent</option>
              <option value="good">Good</option>
              <option value="fair">Fair</option>
              <option value="poor">Poor</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Status</label>
            <select name="status" id="edit-status" class="form-control">
              <option value="active">Active</option>
              <option value="disposed">Disposed</option>
              <option value="under_maintenance">Under Maintenance</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Location</label>
          <input type="text" name="location" id="edit-location" class="form-control">
        </div>
        <div class="form-group">
          <label class="form-label">Description</label>
          <textarea name="description" id="edit-desc" class="form-control" rows="2"></textarea>
        </div>
        <div class="flex gap-2">
          <button type="submit" class="btn btn-primary">Save Changes</button>
          <button type="button" onclick="document.getElementById('editModal').style.display='none'" class="btn btn-outline">Cancel</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
function openEditAsset(btn) {
  var d = btn.dataset;
  document.getElementById('editForm').action = '/admin/assets/' + d.id + '/edit';
  document.getElementById('edit-name').value     = d.name;
  document.getElementById('edit-category').value = d.category;
  document.getElementById('edit-value').value    = d.value;
  document.getElementById('edit-condition').value= d.condition;
  document.getElementById('edit-status').value   = d.status;
  document.getElementById('edit-location').value = d.location;
  document.getElementById('edit-desc').value     = d.desc;
  document.getElementById('editModal').style.display = 'flex';
}
</script>

<%- include('../partials/foot') %>
