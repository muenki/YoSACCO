<%- include('../partials/head', { title: 'Loan Management', activePage: 'admin-loans', group }) %>

<% const q = locals.query || {}; %>
<% if (q.success === 'loan_approved') { %><div class="alert alert-success">Loan approved. Approval email sent to member.</div><% } %>
<% if (q.success === 'loan_declined') { %><div class="alert alert-danger" style="background:var(--warning-bg);color:var(--warning);border-color:#f6e05e;">Loan declined. Member has been notified by email.</div><% } %>
<% if (q.success === 'repayment_recorded') { %><div class="alert alert-success">Repayment recorded. Receipt email sent to member.</div><% } %>

<!-- Stats -->
<div class="stats-grid mb-6">
  <div class="stat-card">
    <div class="label">Pending Requests</div>
    <div class="value"><%= loans.filter(l=>l.status==='pending').length %></div>
    <div class="sub <%= loans.filter(l=>l.status==='pending').length > 0 ? 'warn' : '' %>">Awaiting review</div>
  </div>
  <div class="stat-card">
    <div class="label">Active Loans</div>
    <div class="value"><%= loans.filter(l=>l.status==='active').length %></div>
  </div>
  <div class="stat-card">
    <div class="label">Outstanding Balance</div>
    <div class="value" style="font-size:18px;">UGX <%= loans.filter(l=>l.status==='active').reduce((s,l)=>s+(l.totalRepayable-l.amountRepaid),0).toLocaleString() %></div>
  </div>
  <div class="stat-card">
    <div class="label">Loans Fully Repaid</div>
    <div class="value"><%= loans.filter(l=>l.status==='repaid').length %></div>
    <div class="sub">All time</div>
  </div>
</div>

<!-- PENDING LOANS INBOX -->
<% const pendingLoans = loans.filter(l => l.status === 'pending'); %>
<% if (pendingLoans.length > 0) { %>
<div class="section-head">
  <h2>Loan Requests Inbox <span class="badge badge-warning" style="margin-left:8px;"><%= pendingLoans.length %> pending</span></h2>
</div>
<% pendingLoans.forEach(loan => { %>
<div class="loan-card pending" style="background:#fffbeb;">
  <div class="flex-between mb-3">
    <div class="member-row">
      <div class="avatar" style="background:#fef3c7;color:#b7791f;"><%= loan.member ? loan.member.name.split(' ').map(n=>n[0]).join('') : '?' %></div>
      <div>
        <div class="name"><%= loan.member ? loan.member.name : 'Unknown' %></div>
        <div class="id"><%= loan.member ? loan.member.memberId : '' %> · Applied <%= new Date(loan.appliedAt).toLocaleDateString() %></div>
      </div>
    </div>
    <span class="badge badge-warning">Pending Review</span>
  </div>
  <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:16px;padding:14px;background:white;border-radius:8px;border:1px solid var(--border);">
    <div><div class="text-xs text-muted">Amount Requested</div><div class="font-semibold">UGX <%= loan.amount.toLocaleString() %></div></div>
    <div><div class="text-xs text-muted">Purpose</div><div class="font-semibold"><%= loan.purpose %></div></div>
    <div><div class="text-xs text-muted">Repayment Period</div><div class="font-semibold"><%= loan.repaymentMonths %> months</div></div>
    <div><div class="text-xs text-muted">Member Savings</div><div class="font-semibold text-teal">UGX <%= (loan.savingsBalance||0).toLocaleString() %></div></div>
  </div>
  <div class="flex gap-2" style="flex-wrap:wrap;">
    <form method="POST" action="/admin/loans/<%= loan.id %>/approve" style="display:flex;gap:8px;align-items:center;">
      <input type="text" name="notes" class="form-control" style="width:240px;" placeholder="Optional note to member...">
      <button type="submit" class="btn btn-success">✓ Approve Loan</button>
    </form>
    <form method="POST" action="/admin/loans/<%= loan.id %>/decline" style="display:flex;gap:8px;align-items:center;">
      <input type="text" name="notes" class="form-control" style="width:200px;" placeholder="Reason for decline...">
      <button type="submit" class="btn btn-danger">✗ Decline</button>
    </form>
  </div>
</div>
<% }) %>
<% } %>

<!-- ALL LOANS TABLE -->
<div class="section-head mt-4"><h2>All Loans</h2></div>
<div class="card p-0">
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Member</th>
          <th>Amount</th>
          <th>Purpose</th>
          <th>Repayment</th>
          <th>Progress</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (loans.length === 0) { %>
        <tr><td colspan="7" style="text-align:center;color:var(--text-muted);padding:32px;">No loan records found.</td></tr>
        <% } %>
        <% loans.forEach(loan => { %>
        <tr>
          <td>
            <div class="member-row">
              <div class="avatar" style="width:28px;height:28px;font-size:10px;"><%= loan.member ? loan.member.name.split(' ').map(n=>n[0]).join('') : '?' %></div>
              <div>
                <div class="text-sm font-semibold"><%= loan.member ? loan.member.name : 'Unknown' %></div>
                <div class="text-xs text-muted"><%= loan.member ? loan.member.memberId : '' %></div>
              </div>
            </div>
          </td>
          <td class="font-semibold">UGX <%= loan.amount.toLocaleString() %></td>
          <td class="text-sm"><%= loan.purpose %></td>
          <td class="text-sm">
            <% if (loan.status === 'active') { %>
              UGX <%= loan.monthlyInstallment.toLocaleString() %>/mo
            <% } else { %>
              <%= loan.repaymentMonths %> months
            <% } %>
          </td>
          <td style="min-width:120px;">
            <% if (loan.status === 'active') { %>
              <div class="progress"><div class="progress-bar" style="width:<%= Math.round(loan.amountRepaid/loan.totalRepayable*100) %>%;background:var(--success);"></div></div>
              <div class="text-xs text-muted mt-1">UGX <%= loan.amountRepaid.toLocaleString() %> / <%= loan.totalRepayable.toLocaleString() %></div>
            <% } else if (loan.status === 'repaid') { %>
              <div class="progress"><div class="progress-bar" style="width:100%;background:var(--success);"></div></div>
            <% } else { %>
              <span class="text-muted text-xs">—</span>
            <% } %>
          </td>
          <td>
            <span class="badge badge-<%= loan.status==='active'?'info':loan.status==='pending'?'warning':loan.status==='repaid'?'success':'danger' %>">
              <%= loan.status.charAt(0).toUpperCase()+loan.status.slice(1) %>
            </span>
          </td>
          <td>
            <% if (loan.status === 'active') { %>
            <button onclick="openRepayModal('<%= loan.id %>')" class="btn btn-sm btn-primary">Record Repayment</button>
            <% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<!-- Repayment Modal -->
<div id="repayModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:999;align-items:center;justify-content:center;">
  <div class="card" style="width:420px;">
    <div class="card-header">
      <h3>Record Loan Repayment</h3>
      <button onclick="closeRepayModal()" style="background:none;border:none;cursor:pointer;font-size:18px;">✕</button>
    </div>
    <div class="card-body">
      <form id="repayForm" method="POST">
        <div class="form-group">
          <label class="form-label">Repayment Amount (UGX) *</label>
          <input type="number" name="amount" class="form-control" placeholder="e.g. 540000" required>
        </div>
        <p class="text-xs text-muted mb-4">A receipt email will be sent to the member automatically.</p>
        <div class="flex gap-2">
          <button type="submit" class="btn btn-primary">Record Repayment</button>
          <button type="button" onclick="closeRepayModal()" class="btn btn-outline">Cancel</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
function openRepayModal(loanId) {
  document.getElementById('repayForm').action = '/admin/loans/' + loanId + '/repayment';
  document.getElementById('repayModal').style.display = 'flex';
}
function closeRepayModal() {
  document.getElementById('repayModal').style.display = 'none';
}
</script>

<%- include('../partials/foot') %>
