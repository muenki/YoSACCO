<%- include('../partials/head', { title: 'Savings Management', activePage: 'admin-savings', group }) %>

<style>
/* ── Print styles ───────────────────────────────────────────── */
.member-ledger-template { display: none !important; }

@media print {
  /* Full ledger print */
  body.print-full .sidebar,
  body.print-full .topbar,
  body.print-full .page-footer,
  body.print-full .no-print { display: none !important; }
  body.print-full .main { margin-left: 0 !important; }
  body.print-full .print-header { display: block !important; }

  /* Individual member ledger print */
  body.print-member * { visibility: hidden; }
  body.print-member .member-ledger-template.selected,
  body.print-member .member-ledger-template.selected * { visibility: visible; }
  body.print-member .member-ledger-template.selected {
    display: block !important;
    position: fixed;
    top: 0; left: 0; width: 100%;
  }
}
.print-header { display: none; }
</style>

<!-- Individual member ledger print templates -->
<% members.forEach(function(m, idx) { %>
<div class="member-ledger-template" id="mledger-<%= idx %>">
  <div style="max-width:700px;margin:40px auto;font-family:Arial,sans-serif;padding:32px;">
    <!-- Header -->
    <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:20px;padding-bottom:16px;border-bottom:2px solid #90E0EF;">
      <div>
        <% if(group.logo){ %><img src="<%= group.logo %>" style="height:44px;margin-bottom:6px;display:block;"><% } %>
        <div style="font-size:16px;font-weight:700;color:#0A2342;"><%= group.name %></div>
        <div style="font-size:12px;color:#888;">Member Savings Statement</div>
      </div>
      <div style="text-align:right;">
        <div style="font-size:12px;color:#666;">Printed: <%= new Date().toLocaleDateString('en-UG',{day:'numeric',month:'long',year:'numeric'}) %></div>
      </div>
    </div>
    <!-- Member Details -->
    <div style="background:#f6f8fa;padding:14px 18px;border-radius:8px;margin-bottom:20px;display:flex;gap:32px;">
      <div>
        <div style="font-size:10px;color:#888;text-transform:uppercase;letter-spacing:.06em;margin-bottom:4px;">Member</div>
        <div style="font-weight:700;font-size:15px;color:#0A2342;"><%= m.name %></div>
        <div style="font-size:12px;color:#555;"><%= m.email %></div>
      </div>
      <div>
        <div style="font-size:10px;color:#888;text-transform:uppercase;letter-spacing:.06em;margin-bottom:4px;">Member ID</div>
        <div style="font-weight:700;color:#0A2342;"><%= m.memberId||'—' %></div>
      </div>
      <div>
        <div style="font-size:10px;color:#888;text-transform:uppercase;letter-spacing:.06em;margin-bottom:4px;">Total Balance</div>
        <div style="font-weight:800;font-size:18px;color:#90E0EF;">UGX <%= m.balance.toLocaleString() %></div>
      </div>
      <div>
        <div style="font-size:10px;color:#888;text-transform:uppercase;letter-spacing:.06em;margin-bottom:4px;">Share Capital</div>
        <div style="font-weight:700;color:#0A2342;">UGX <%= (m.shareCapitalPaid||0).toLocaleString() %></div>
        <div style="font-size:11px;color:#888;">of UGX <%= (m.shareCapitalTarget||0).toLocaleString() %> target</div>
      </div>
    </div>
    <!-- Transactions table -->
    <table style="width:100%;border-collapse:collapse;margin-bottom:20px;font-size:12px;">
      <thead>
        <tr style="background:#0A2342;color:#fff;">
          <th style="padding:9px 12px;text-align:left;">#</th>
          <th style="padding:9px 12px;text-align:left;">Date</th>
          <th style="padding:9px 12px;text-align:left;">Description</th>
          <th style="padding:9px 12px;text-align:center;">Type</th>
          <th style="padding:9px 12px;text-align:right;">Amount (UGX)</th>
          <th style="padding:9px 12px;text-align:right;">Balance (UGX)</th>
        </tr>
      </thead>
      <tbody>
        <% var running = 0; %>
        <% if(m.transactions && m.transactions.length){ %>
          <% m.transactions.forEach(function(t, ti){ running += t.amount; %>
          <tr style="background:<%= ti%2===0?'#fff':'#f9fbfd' %>;">
            <td style="padding:8px 12px;color:#888;"><%= ti+1 %></td>
            <td style="padding:8px 12px;"><%= new Date(t.date).toLocaleDateString('en-UG',{day:'2-digit',month:'short',year:'numeric'}) %></td>
            <td style="padding:8px 12px;"><%= t.description||'—' %></td>
            <td style="padding:8px 12px;text-align:center;"><span style="background:#e8f4fd;color:#2b6cb0;padding:2px 8px;border-radius:10px;font-size:10px;text-transform:capitalize;"><%= (t.type||'').replace(/_/g,' ') %></span></td>
            <td style="padding:8px 12px;text-align:right;color:#1a7f4b;font-weight:600;">+ <%= t.amount.toLocaleString() %></td>
            <td style="padding:8px 12px;text-align:right;font-weight:700;"><%= running.toLocaleString() %></td>
          </tr>
          <% }); %>
        <% } else { %>
          <tr><td colspan="6" style="text-align:center;padding:20px;color:#888;">No transactions on record.</td></tr>
        <% } %>
        <tr style="background:#90E0EF;color:#fff;font-weight:700;">
          <td colspan="4" style="padding:10px 12px;text-align:right;">CLOSING BALANCE</td>
          <td style="padding:10px 12px;text-align:right;"></td>
          <td style="padding:10px 12px;text-align:right;">UGX <%= m.balance.toLocaleString() %></td>
        </tr>
      </tbody>
    </table>
    <div style="text-align:center;font-size:11px;color:#bbb;border-top:1px solid #eee;padding-top:12px;">
      <%= group.name %> · Powered by YoSACCO · +256 756 683 141
    </div>
  </div>
</div>
<% }); %>

<!-- ── Page Content ──────────────────────────────────────────── -->
<% const q = locals.query || {}; %>
<% if (q.success === 'savings_posted') { %><div class="alert alert-success no-print">Savings posted. Receipt email sent to member.</div><% } %>
<% if (q.success === 'deposit_confirmed') { %><div class="alert alert-success no-print">Deposit confirmed. Receipt sent to member.</div><% } %>
<% if (q.success === 'deposit_rejected') { %><div class="alert alert-warning no-print">Deposit rejected and removed.</div><% } %>

<% if (locals.pendingDeposits && pendingDeposits.length > 0) { %>
<div class="card mb-6 no-print" style="border-left:4px solid var(--warning);">
  <div class="card-header" style="background:#fffbeb;">
    <h3 style="color:#b7791f;">⏳ Pending Deposits (<%= pendingDeposits.length %>)</h3>
    <span class="text-sm text-muted">Members have submitted payment intents awaiting your confirmation</span>
  </div>
  <div class="card-body" style="padding:0;">
    <table>
      <thead><tr><th>Member</th><th>Amount</th><th>Method</th><th>Reference</th><th>Submitted</th><th>Actions</th></tr></thead>
      <tbody>
        <% pendingDeposits.forEach(function(dep){ %>
        <tr>
          <td>
            <div class="member-row">
              <div class="avatar" style="background:#fef3c7;color:#b7791f;"><%= dep.member ? dep.member.name.split(' ').map(function(n){return n[0];}).join('') : '?' %></div>
              <div><div class="font-semibold text-sm"><%= dep.member ? dep.member.name : 'Unknown' %></div><div class="text-xs text-muted"><%= dep.member ? dep.member.memberId : '' %></div></div>
            </div>
          </td>
          <td class="font-semibold">UGX <%= dep.amount.toLocaleString() %></td>
          <td class="text-sm"><%= dep.paymentMethod || dep.description %></td>
          <td class="text-sm text-muted"><%= dep.transactionRef || '—' %></td>
          <td class="text-sm text-muted"><%= new Date(dep.date).toLocaleDateString() %></td>
          <td>
            <div class="flex gap-2">
              <form method="POST" action="/admin/savings/<%= dep.id %>/confirm" style="display:inline;">
                <button class="btn btn-sm btn-success">✓ Confirm</button>
              </form>
              <form method="POST" action="/admin/savings/<%= dep.id %>/reject" style="display:inline;">
                <button class="btn btn-sm btn-outline" style="color:var(--danger);border-color:var(--danger);">✗ Reject</button>
              </form>
            </div>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>
<% } %>


<!-- Print header for full ledger -->
<div class="print-header" style="text-align:center;margin-bottom:20px;padding-bottom:16px;border-bottom:2px solid #90E0EF;">
  <% if(group.logo){ %><img src="<%= group.logo %>" style="height:50px;margin-bottom:8px;"><br><% } %>
  <h2 style="margin:0;"><%= group.name %></h2>
  <p style="margin:4px 0;font-size:14px;"><strong>Savings Ledger</strong></p>
  <p style="font-size:12px;color:#666;">Printed: <%= new Date().toLocaleDateString('en-UG',{day:'numeric',month:'long',year:'numeric'}) %></p>
</div>

<div class="grid-2 gap-4 mb-6 no-print">
  <!-- Post Savings Form -->
  <div class="card">
    <div class="card-header"><h3>Post Savings Contribution</h3></div>
    <div class="card-body">
      <form method="POST" action="/admin/savings/post">
        <div class="form-group">
          <label class="form-label">Select Member *</label>
          <select name="memberId" class="form-control" required>
            <option value="">— Choose member —</option>
            <% members.forEach(function(m){ %>
            <option value="<%= m.id %>"><%= m.name %> (<%= m.memberId||'?' %>) — UGX <%= m.balance.toLocaleString() %></option>
            <% }); %>
          </select>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Amount (UGX) *</label>
            <input type="number" name="amount" class="form-control" placeholder="e.g. 50000" min="1000" required>
          </div>
          <div class="form-group">
            <label class="form-label">Type</label>
            <select name="type" class="form-control">
              <option value="contribution">Monthly Contribution</option>
              <option value="share_capital">Share Capital</option>
              <option value="interest">Interest Credit</option>
              <option value="dividend">Dividend</option>
              <option value="other">Other</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Description</label>
          <input type="text" name="description" class="form-control" placeholder="e.g. Monthly contribution — April 2025">
        </div>
        <p class="text-xs text-muted mb-4">A receipt email will automatically be sent to the member upon posting.</p>
        <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;">Post Savings &amp; Send Receipt</button>
      </form>
    </div>
  </div>

  <!-- Members with arrears -->
  <div>
    <div class="stats-grid" style="grid-template-columns:1fr 1fr;margin-bottom:16px;">
      <div class="stat-card">
        <div class="label">Total Members</div>
        <div class="value"><%= members.length %></div>
      </div>
      <div class="stat-card">
        <div class="label">Group Savings</div>
        <div class="value" style="font-size:18px;">UGX <%= (members.reduce(function(s,m){return s+m.balance;},0)/1000000).toFixed(2) %>M</div>
      </div>
    </div>
    <div class="card">
      <div class="card-body">
        <p class="text-sm font-semibold mb-3">Members with arrears</p>
        <%
          var arrears = members.filter(function(m) {
            if (!m.lastContrib) return true;
            var daysSince = (Date.now() - new Date(m.lastContrib.date)) / (1000*60*60*24);
            return daysSince > 45;
          });
        %>
        <% if (!arrears.length) { %>
          <p class="text-sm text-muted">All members are up to date ✓</p>
        <% } else { %>
          <% arrears.forEach(function(m){ %>
          <div class="flex-between text-sm mb-2">
            <span><%= m.name %></span>
            <span class="badge badge-warning">Overdue</span>
          </div>
          <% }); %>
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- Savings Ledger Table -->
<div class="flex-between mb-3">
  <h2>Savings Ledger</h2>
  <div class="flex gap-2 no-print">
    <button onclick="printFullLedger()" class="btn btn-sm btn-outline">🖨 Print Full Ledger</button>
  </div>
</div>

<div class="card p-0">
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Member</th>
          <th>Member ID</th>
          <th>Monthly Contribution</th>
          <th>Last Contribution</th>
          <th>Total Balance</th>
          <th>Share Capital</th>
          <th>Status</th>
          <th class="no-print">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% members.forEach(function(m, idx){ %>
        <tr>
          <td>
            <div class="member-row">
              <div class="avatar"><%= m.name.split(' ').map(function(n){return n[0];}).join('') %></div>
              <span><%= m.name %></span>
            </div>
          </td>
          <td><code style="font-size:12px;background:#f0f4f8;padding:2px 6px;border-radius:4px;"><%= m.memberId||'—' %></code></td>
          <td>UGX <%= (m.monthlyContribution||0).toLocaleString() %></td>
          <td class="text-sm text-muted"><%= m.lastContrib ? new Date(m.lastContrib.date).toLocaleDateString() : 'Never' %></td>
          <td class="font-semibold text-teal">UGX <%= m.balance.toLocaleString() %></td>
          <td>
            <div style="font-size:12px;">UGX <%= (m.shareCapitalPaid||0).toLocaleString() %> / <%= (m.shareCapitalTarget||0).toLocaleString() %></div>
            <div class="progress" style="margin-top:4px;height:4px;">
              <div class="progress-bar" style="width:<%= m.shareCapitalTarget>0?Math.min(100,Math.round((m.shareCapitalPaid||0)/(m.shareCapitalTarget)*100)):0 %>%"></div>
            </div>
          </td>
          <td>
            <%
              var overdue = !m.lastContrib || (Date.now() - new Date(m.lastContrib.date)) / (1000*60*60*24) > 45;
            %>
            <% if (overdue) { %><span class="badge badge-warning">Overdue</span>
            <% } else { %><span class="badge badge-success">Up to date</span><% } %>
          </td>
          <td class="no-print">
            <div class="flex gap-1">
              <a href="/admin/members/<%= m.id %>" class="btn btn-sm btn-outline">View</a>
              <button onclick="printMemberLedger(<%= idx %>)" class="btn btn-sm btn-outline" title="Print member statement">🖨</button>
            </div>
          </td>
        </tr>
        <% }); %>
        <!-- Totals row -->
        <tr style="background:var(--bg);font-weight:700;" class="print-only" style="display:none;">
          <td colspan="4" style="padding:10px 16px;text-align:right;">GROUP TOTAL</td>
          <td style="padding:10px 16px;color:var(--teal);">UGX <%= members.reduce(function(s,m){return s+m.balance;},0).toLocaleString() %></td>
          <td style="padding:10px 16px;">UGX <%= members.reduce(function(s,m){return s+(m.shareCapitalPaid||0);},0).toLocaleString() %></td>
          <td colspan="2"></td>
        </tr>
      </tbody>
    </table>
  </div>
</div>

<!-- Totals visible when printing full ledger -->
<div id="ledger-totals" style="display:none;margin-top:16px;padding:14px 16px;background:#f0f9f0;border-radius:8px;border:2px solid #90E0EF;">
  <div style="display:flex;justify-content:space-between;align-items:center;">
    <span style="font-weight:700;font-size:15px;">Group Total Savings</span>
    <span style="font-weight:800;font-size:20px;color:#90E0EF;">UGX <%= members.reduce(function(s,m){return s+m.balance;},0).toLocaleString() %></span>
  </div>
  <div style="display:flex;justify-content:space-between;align-items:center;margin-top:6px;">
    <span style="font-size:13px;color:#555;">Total Share Capital</span>
    <span style="font-weight:700;font-size:15px;">UGX <%= members.reduce(function(s,m){return s+(m.shareCapitalPaid||0);},0).toLocaleString() %></span>
  </div>
</div>

<script>
function printFullLedger() {
  // Show totals box
  document.getElementById('ledger-totals').style.display = 'block';
  document.body.classList.add('print-full');
  window.print();
  setTimeout(function() {
    document.body.classList.remove('print-full');
    document.getElementById('ledger-totals').style.display = 'none';
  }, 2000);
}

function printMemberLedger(idx) {
  // Hide any previously selected
  var prev = document.querySelector('.member-ledger-template.selected');
  if (prev) prev.classList.remove('selected');
  var target = document.getElementById('mledger-' + idx);
  if (!target) return;
  target.classList.add('selected');
  document.body.classList.add('print-member');
  window.print();
  setTimeout(function() {
    document.body.classList.remove('print-member');
    target.classList.remove('selected');
  }, 2000);
}
</script>

<%- include('../partials/foot') %>
