<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Quotation <%= quoteNumber %></title>
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { background:#f0f0f0; font-family:Arial,sans-serif; font-size:13px; color:#1a1a1a; }
    @media print {
      body { background:#fff; }
      .no-print { display:none!important; }
      .page { box-shadow:none!important; margin:0!important; }
    }
    .no-print { background:#1a1a1a; color:#fff; padding:10px 28px; display:flex; justify-content:space-between; align-items:center; }
    .no-print button { background:#D35050; color:#fff; border:none; padding:9px 22px; border-radius:6px; cursor:pointer; font-weight:600; font-size:13px; margin-left:8px; }
    .no-print button.sec { background:#444; }

    /* PAGE */
    .page { max-width:780px; margin:18px auto; background:#fff; box-shadow:0 3px 18px rgba(0,0,0,0.12); }

    /* LETTERHEAD */
    .lh-header { padding:18px 32px 0; }
    .lh-header-inner { display:flex; justify-content:space-between; align-items:flex-start; }
    .lh-logo img { height:66px; width:auto; }
    .lh-address { text-align:right; font-size:10.5px; line-height:1.75; color:#000; font-family:'Times New Roman',serif; }
    .lh-address a { color:#000; text-decoration:none; }
    .lh-lines { margin:8px 32px 0; display:flex; flex-direction:column; gap:3px; }
    .lh-line { height:2px; width:100%; }
    .lh-line-gold  { background:#FFC000; }
    .lh-line-green { background:#375623; }
    .lh-line-red   { background:#FF0000; }

    /* BODY */
    .lh-body { padding:22px 32px; }

    /* DOC TITLE BAR */
    .doc-title-bar { background:#1a1a1a; color:#fff; padding:10px 16px; display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; }
    .doc-title { font-size:16px; font-weight:700; letter-spacing:.04em; }
    .doc-meta { text-align:right; font-size:11px; opacity:0.75; line-height:1.6; }
    .doc-num { font-size:14px; font-weight:700; color:#FFC000; }

    /* ADDRESSES */
    .addresses { display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-bottom:20px; }
    .addr-box { background:#f8f8f8; border-left:3px solid #D35050; padding:12px 14px; }
    .addr-label { font-size:9px; font-weight:700; text-transform:uppercase; letter-spacing:.08em; color:#D35050; margin-bottom:5px; }
    .addr-name { font-size:14px; font-weight:700; margin-bottom:3px; }
    .addr-detail { font-size:11px; color:#555; line-height:1.6; }

    /* FEATURES */
    .features { background:#fff8e1; border:1px solid #FFC000; border-radius:4px; padding:12px 16px; margin-bottom:18px; }
    .features-title { font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:#b8860b; margin-bottom:8px; }
    .features-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:3px 10px; font-size:11px; }
    .features-grid span::before { content:'✓ '; color:#375623; font-weight:700; }

    /* TABLE */
    .tbl-title { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.05em; color:#555; margin-bottom:8px; }
    table.items { width:100%; border-collapse:collapse; margin-bottom:16px; font-size:12px; }
    table.items thead tr { background:#1a1a1a; color:#fff; }
    table.items th { padding:8px 12px; text-align:left; font-size:11px; }
    table.items th:last-child { text-align:right; }
    table.items td { padding:10px 12px; border-bottom:1px solid #eee; vertical-align:top; }
    table.items td:last-child { text-align:right; font-weight:700; }
    table.items tr:nth-child(even) td { background:#fafafa; }
    .item-name { font-weight:600; margin-bottom:2px; }
    .item-detail { font-size:10px; color:#888; }
    .badge { display:inline-block; padding:1px 7px; border-radius:10px; font-size:9px; font-weight:700; margin-left:5px; vertical-align:middle; }
    .badge-once   { background:#fef3c7; color:#b7791f; }
    .badge-monthly{ background:#dbeafe; color:#1d4ed8; }
    .badge-annual { background:#dcfce7; color:#15803d; }

    /* TOTALS */
    .totals-wrap { display:flex; justify-content:flex-end; margin-bottom:16px; }
    .totals { min-width:240px; font-size:12px; }
    .totals-row { display:flex; justify-content:space-between; padding:5px 0; border-bottom:1px solid #eee; }
    .totals-total { display:flex; justify-content:space-between; padding:10px 0; font-size:17px; font-weight:800; border-top:2.5px solid #1a1a1a; margin-top:2px; }

    /* VALIDITY */
    .validity { background:#fff8e1; border:1px solid #FFC000; padding:10px 14px; font-size:11px; color:#7c5800; margin-bottom:14px; border-radius:3px; }

    /* NOTES */
    .notes { background:#f8f8f8; padding:10px 14px; font-size:11px; margin-bottom:14px; border-left:3px solid #aaa; }

    /* TERMS */
    .terms { font-size:10px; color:#888; line-height:1.75; border-top:1px solid #eee; padding-top:12px; margin-bottom:14px; }

    /* SIGNATURES */
    .sigs { display:grid; grid-template-columns:1fr 1fr; gap:36px; margin-bottom:14px; }
    .sig-box { border-top:1px solid #ccc; padding-top:7px; font-size:10px; color:#888; line-height:2; }

    /* LETTERHEAD FOOTER */
    .lh-footer { border-top:3px solid #FFC000; padding:9px 32px; text-align:center; font-size:10px; color:#555; font-family:'Times New Roman',serif; }
  </style>
</head>
<body>

<div class="no-print">
  <span style="font-weight:600;">Quotation Preview — <%= quoteNumber %></span>
  <div>
    <button onclick="window.print()">🖨 Print / Save PDF</button>
    <button class="sec" onclick="window.close()">✕ Close</button>
  </div>
</div>

<div class="page">

  <!-- MUENKI LETTERHEAD HEADER -->
  <div class="lh-header">
    <div class="lh-header-inner">
      <div class="lh-logo">
        <img src="/assets/muenki_logo.jpg" alt="MUENKI Investments LTD">
      </div>
      <div class="lh-address">
        P.O.BOX 5445 Kampala, Uganda<br>
        Plot 4, Semawata Road. Ntinda<br>
        Email: <a href="mailto:muenkinvestments@gmail.com">muenkinvestments@gmail.com</a><br>
        Tel: +256 756 683 141
      </div>
    </div>
  </div>
  <div class="lh-lines">
    <div class="lh-line lh-line-gold"></div>
    <div class="lh-line lh-line-green"></div>
    <div class="lh-line lh-line-red"></div>
  </div>

  <div class="lh-body">

    <!-- DOC TITLE BAR -->
    <div class="doc-title-bar">
      <div class="doc-title">QUOTATION</div>
      <div class="doc-meta">
        <div class="doc-num"><%= quoteNumber %></div>
        Date: <%= today.toLocaleDateString('en-UG',{day:'numeric',month:'long',year:'numeric'}) %><br>
        Valid Until: <%= validUntil.toLocaleDateString('en-UG',{day:'numeric',month:'long',year:'numeric'}) %>
      </div>
    </div>

    <!-- ADDRESSES -->
    <div class="addresses">
      <div class="addr-box">
        <div class="addr-label">From</div>
        <div class="addr-name">MUENKI Investments LTD</div>
        <div class="addr-detail">YoSACCO Platform · Kampala, Uganda<br>muenkinvestments@gmail.com · +256 756 683 141</div>
      </div>
      <div class="addr-box">
        <div class="addr-label">Prepared For</div>
        <div class="addr-name"><%= clientName %></div>
        <div class="addr-detail">
          <% if(saccoType){ %><%= saccoType %><br><% } %>
          <% if(clientEmail){ %><%= clientEmail %><br><% } %>
          <% if(clientContact){ %><%= clientContact %><% } %>
        </div>
      </div>
    </div>

    <!-- FEATURES -->
    <div class="features">
      <div class="features-title">Platform Features Included in All Plans</div>
      <div class="features-grid">
        <span>Member management</span><span>Savings tracking</span><span>Loan management</span><span>3-stage approvals</span>
        <span>Financial reports</span><span>Member portal</span><span>Project management</span><span>Asset register</span>
        <span>Income distribution</span><span>Email notifications</span><span>Print statements</span><span>Unlimited members</span>
      </div>
    </div>

    <!-- ITEMS -->
    <div class="tbl-title">Quotation Items</div>
    <table class="items">
      <thead><tr><th style="width:52%">Description</th><th style="text-align:center">Qty</th><th style="text-align:right">Unit Price</th><th style="text-align:right">Total (UGX)</th></tr></thead>
      <tbody>
        <% items.forEach(function(item,i){ %>
        <tr>
          <td>
            <div class="item-name"><%= item.desc %><span class="badge badge-<%= item.type==='once-off'?'once':item.type %>"><%= item.type==='once-off'?'Once-off':item.type==='monthly'?'Monthly':'Annual' %></span></div>
            <% if(item.detail){ %><div class="item-detail"><%= item.detail %></div><% } %>
          </td>
          <td style="text-align:center"><%= item.qty %></td>
          <td style="text-align:right">UGX <%= item.unit.toLocaleString() %></td>
          <td>UGX <%= item.total.toLocaleString() %></td>
        </tr>
        <% }); %>
        <% if(!items.length){ %><tr><td colspan="4" style="text-align:center;padding:16px;color:#aaa;">No items selected.</td></tr><% } %>
      </tbody>
    </table>

    <!-- TOTALS -->
    <div class="totals-wrap">
      <div class="totals">
        <%
          var _sub = locals.subtotal || 0;
          var _vat = locals.vat != null ? locals.vat : Math.round(_sub * 0.18);
          var _total = _sub + _vat;
        %>
        <div class="totals-row"><span>Subtotal</span><span>UGX <%= _sub.toLocaleString() %></span></div>
        <div class="totals-row"><span>VAT (18%)</span><span>UGX <%= _vat.toLocaleString() %></span></div>
        <div class="totals-total"><span>TOTAL DUE (inc. VAT)</span><span>UGX <%= _total.toLocaleString() %></span></div>
      </div>
    </div>

    <!-- VALIDITY -->
    <div class="validity">⏳ <strong>Valid for 30 days</strong> — expires <%= validUntil.toLocaleDateString('en-UG',{day:'numeric',month:'long',year:'numeric'}) %>. Prices subject to change after expiry.</div>

    <% if(notes){ %><div class="notes"><strong>Notes:</strong> <%= notes %></div><% } %>

    <!-- TERMS -->
    <div class="terms">
      <strong style="color:#444;">Terms & Conditions:</strong> &nbsp;
      1. Payment due within 14 days of invoice. &nbsp;
      2. Setup and data entry fees are non-refundable once work commences. &nbsp;
      3. Subscriptions begin on date of first payment. &nbsp;
      4. Annual subscription includes all updates and email support. &nbsp;
      5. Service may be suspended for invoices overdue by 30+ days. &nbsp;
      6. All prices in UGX, excluding bank transfer charges.
    </div>

    <!-- SIGNATURES -->
    <div class="sigs">
      <div class="sig-box">Authorised — MUENKI Investments LTD<br>Name: ___________________________<br>Signature: ______________________<br>Date: ___________________________</div>
      <div class="sig-box">Accepted — <%= clientName %><br>Name: ___________________________<br>Signature: ______________________<br>Date: ___________________________</div>
    </div>

  </div><!-- /lh-body -->

  <!-- LETTERHEAD FOOTER -->
  <div class="lh-footer">
    <strong>MUENKI Investments LTD</strong> — YoSACCO Platform &nbsp;·&nbsp; muenkinvestments@gmail.com &nbsp;·&nbsp; +256 756 683 141 &nbsp;·&nbsp; Plot 4, Semawata Road. Ntinda, Kampala
  </div>

</div><!-- /page -->
</body>
</html>
