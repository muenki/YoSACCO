<%- include('../partials/head', { title: 'Audit Trail', activePage: 'super-audit' }) %>

<div class="card">
  <div class="card-header"><h3>Platform Audit Log</h3></div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Timestamp</th>
          <th>User</th>
          <th>Action</th>
          <th>Detail</th>
          <th>Group</th>
        </tr>
      </thead>
      <tbody>
        <% if (log.length === 0) { %>
        <tr><td colspan="5" style="text-align:center;color:var(--text-muted);padding:32px;">No audit entries yet.</td></tr>
        <% } %>
        <% log.forEach(entry => { %>
        <tr>
          <td class="text-sm text-muted"><%= new Date(entry.timestamp).toLocaleString() %></td>
          <td>
            <% if (entry.user) { %>
            <div class="font-semibold text-sm"><%= entry.user.name %></div>
            <div class="text-xs text-muted"><%= entry.user.email %></div>
            <% } else { %><span class="text-muted">System</span><% } %>
          </td>
          <td><span class="badge badge-info text-xs"><%= entry.action %></span></td>
          <td class="text-sm"><%= entry.detail %></td>
          <td class="text-sm text-muted"><%= entry.group ? entry.group.name : '—' %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/foot') %>
