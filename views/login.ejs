<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>YoSACCO — Online SACCO Platform</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/app.css">
</head>
<body>
  <div class="login-page">
    <div class="login-box">
      <div class="login-logo">
        <h1>Yo<span>SACCO</span></h1>
        <p>Online SACCO Management Platform</p>
      </div>

      <% if (error) { %>
        <div class="alert alert-danger">
          <% if (error === 'session_expired') { %>Your session has expired. Please log in again.<% } 
          else if (error === 'user_not_found') { %>Account not found or deactivated.<% }
          else { %><%= error %><% } %>
        </div>
      <% } %>

      <% if (success === 'logged_out') { %>
        <div class="alert alert-success">You have been logged out successfully.</div>
      <% } %>

      <form method="POST" action="/login">
        <div class="form-group">
          <label class="form-label">Email address</label>
          <input type="email" name="email" class="form-control" placeholder="your@email.com" required autofocus>
        </div>
        <div class="form-group">
          <label class="form-label">Password</label>
          <input type="password" name="password" class="form-control" placeholder="••••••••" required>
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:12px;">
          Sign in to YoSACCO
        </button>
      </form>

      <div style="margin-top:28px;padding-top:20px;border-top:1px solid var(--border);">
        <p style="font-size:12px;color:var(--text-muted);margin-bottom:10px;font-weight:600;">DEMO ACCOUNTS</p>
        <div style="font-size:12px;color:var(--text-muted);display:grid;gap:6px;">
          <div><strong>Super Admin:</strong> superadmin@yosacco.coop / Admin@2025</div>
          <div><strong>SACCO Admin:</strong> admin@kteachers.coop / Admin@2025</div>
          <div><strong>Member:</strong> james.kato@gmail.com / Member@2025</div>
          <div><strong>Member:</strong> aisha.m@gmail.com / Member@2025</div>
        </div>
      </div>

      <p style="text-align:center;font-size:12px;color:var(--text-sm);margin-top:20px;">
        © 2025 YoSACCO · Empowering cooperatives digitally
      </p>
    </div>
  </div>
</body>
</html>
