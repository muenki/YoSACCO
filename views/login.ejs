<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>YoSACCO — Sign In</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/app.css">
</head>
<body>
<div class="login-page">
  <div style="width:420px;">
    <div class="login-box">
      <div class="login-logo" style="text-align:center;margin-bottom:28px;">
        <img src="/assets/logo.png" alt="YoSACCO" style="height:72px;width:auto;object-fit:contain;">
        <p style="color:var(--text-muted);font-size:13px;margin-top:10px;">Online SACCO Management Platform</p>
      </div>

      <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
      <% if (success === 'logged_out') { %><div class="alert alert-success">You have been signed out successfully.</div><% } %>

      <form method="POST" action="/login">
        <div class="form-group">
          <label class="form-label">Email address</label>
          <input type="email" name="email" class="form-control" placeholder="your@email.com" required autofocus>
        </div>
        <div class="form-group">
          <label class="form-label">Password</label>
          <input type="password" name="password" class="form-control" placeholder="••••••••" required>
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:12px;font-size:15px;">
          Sign in to YoSACCO
        </button>
      </form>

      <div style="margin-top:24px;padding-top:18px;border-top:1px solid var(--border);">
        <p style="font-size:11px;color:var(--text-muted);margin-bottom:8px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;">Demo Accounts</p>
        <div style="font-size:12px;color:var(--text-muted);display:grid;gap:5px;">
          <div>🔷 <strong>Super Admin:</strong> superadmin@yosacco.coop / Admin@2025</div>
          <div>🔶 <strong>SACCO Admin:</strong> admin@kteachers.coop / Admin@2025</div>
          <div>🔍 <strong>Credit Officer:</strong> credit@kteachers.coop / Admin@2025</div>
          <div>💰 <strong>Treasurer:</strong> treasurer@kteachers.coop / Admin@2025</div>
          <div>👑 <strong>Chairperson:</strong> chair@kteachers.coop / Admin@2025</div>
          <div>👤 <strong>Member:</strong> james.kato@gmail.com / Member@2025</div>
        </div>
      </div>
    </div>

    <div style="text-align:center;margin-top:16px;font-size:12px;color:rgba(255,255,255,0.5);">
      Powered by <strong style="color:rgba(255,255,255,0.8);">YoSACCO</strong> &nbsp;·&nbsp;
      <a href="tel:+256756683141" style="color:rgba(255,255,255,0.6);">+256 756 683 141</a>
    </div>
  </div>
</div>
</body>
</html>
